<nav class="navbar">
    <div class="container navbar-content">
        <a href="/" class="brand">
            <div class="brand-icon-wrapper">
                <img src="/images/logoSemFundo.png" alt="Camisaria Mendes" class="brand-logo-img">
            </div>
            <div class="brand-text">
                <span class="brand-main">CAMISARIA</span>
                <span class="brand-sub">Mendes</span>
            </div>
        </a>
        <button class="mobile-menu-btn" aria-label="Abrir menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <div class="nav-menu">
            <ul class="nav-links">
                <li><a href="/" class="nav-item">Início</a></li>
                <li><a href="/campanhas" class="nav-item">Campanhas</a></li>
                <li><a href="/como-funciona" class="nav-item">Como funciona</a></li>
                <li><a href="/contato" class="nav-item">Contato</a></li>
                {{#unless admin}}
                <li><a href="/meus-pedidos" class="nav-item">Meus Pedidos</a></li>
                {{/unless}}
            </ul>
            <div class="nav-account">
                {{#if admin}}
                    <button type="button" class="account-toggle" id="accountMenuToggle">
                        <span class="account-greeting">Bem-vindo(a)</span>
                        <span class="account-name">{{admin.username}}</span>
                        <i class="fas fa-chevron-down account-chevron"></i>
                    </button>
                    <div class="account-menu" id="accountMenu">
                        <a href="/admin/dashboard" class="account-menu-item">Área do admin</a>
                        <a href="/admin/logout" class="account-menu-item">Sair</a>
                    </div>
                {{else}}
                    {{#if user}}
                        <button type="button" class="account-toggle" id="accountMenuToggle">
                            <span class="account-greeting">Bem-vindo(a)</span>
                            <span class="account-name">{{user.name}}</span>
                            <i class="fas fa-chevron-down account-chevron"></i>

        background: #f8f9fa;
        padding: 1.5rem;
        border-radius: 8px;
        margin-bottom: 2rem;
        text-align: center;
    }
    .organizer-info span {
        display: block;
        margin-bottom: 0.5rem;
        color: #555;
    }
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
    }
    .product-card {
        background: white;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        overflow: hidden;
        transition: transform 0.3s ease;
    }
    .product-card:hover {
        transform: translateY(-5px);
    }
    .product-image {
        height: 250px;
        background: #eee;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .product-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .no-image-placeholder {
        color: #ccc;
        text-align: center;
    }
    .no-image-placeholder i {
        font-size: 3rem;
        display: block;
        margin-bottom: 0.5rem;
    }
    .product-info {
        padding: 1.5rem;
    }
    .product-meta {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
        font-size: 0.9rem;
        color: #666;
    }
    .product-price {
        font-size: 1.25rem;
        font-weight: bold;
        color: var(--primary-color);
        margin-bottom: 10px;
    }
    .product-sizes {
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        color: #555;
    }
    .btn-buy {
        width: 100%;
    }
</style>

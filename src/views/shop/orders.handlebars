<div class="app-container" style="max-width: 900px; margin: 0 auto; padding: 20px;">
    <h1 style="margin-bottom: 25px; font-weight: 700; color: #333;">Meus Pedidos</h1>

    {{#if error}}
        <div style="background: #ffebee; color: #c62828; padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #ffcdd2;">
            <i class="fas fa-exclamation-circle"></i> {{error}}
        </div>
    {{/if}}

    {{#if orders.length}}
        <div class="orders-list">
            {{#each orders}}
                <div class="order-card">
                    <!-- Header -->
                    <div class="order-header">
                        <div>
                            <span class="order-id">Pedido #{{id}}</span>
                            <span class="order-date">{{createdAt}}</span>
                        </div>
                        <div class="status-badge status-{{status}}">
                            {{#if (eq status 'pending')}} <i class="fas fa-clock"></i> Pendente {{/if}}
                            {{#if (eq status 'approved')}} <i class="fas fa-check-circle"></i> Aprovado {{/if}}
                            {{#if (eq status 'rejected')}} <i class="fas fa-times-circle"></i> Recusado {{/if}}
                            {{#if (eq status 'cancelled')}} <i class="fas fa-ban"></i> Cancelado {{/if}}
                        </div>
                    </div>

                    <!-- Items -->
                    <div class="order-items" style="background: #f9f9f9; padding: 15px; border-radius: 8px; margin: 15px 0;">
                        <h4 style="margin: 0 0 10px 0; font-size: 0.9rem; color: #777; text-transform: uppercase; letter-spacing: 0.5px;">Itens do Pedido</h4>
                        {{#each items}}
                            <div class="item-row" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #eee;">
                                <div class="item-info" style="display: flex; gap: 12px; align-items: center;">
                                    <div style="width: 50px; height: 50px; border-radius: 6px; overflow: hidden; background: #f5f5f5; flex-shrink: 0; border: 1px solid #eee;">
                                        {{#if image}}
                                            <img src="{{image}}" alt="{{name}}" style="width: 100%; height: 100%; object-fit: cover;">
                                        {{else}}
                                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #bbb;">
                                                <i class="fas fa-tshirt"></i>
                                            </div>
                                        {{/if}}
                                    </div>
                                    
                                    <div style="display: flex; flex-direction: column; justify-content: center;">
                                        <div style="display: flex; align-items: center; gap: 6px;">
                                            <span class="item-qty" style="background: #eee; padding: 1px 6px; border-radius: 4px; font-weight: 700; font-size: 0.75rem; color: #555;">{{qty}}x</span>
                                            <span class="item-name" style="font-weight: 600; color: #333; font-size: 0.95rem;">{{name}}</span>
                                        </div>
                                        <span class="item-size" style="font-size: 0.85rem; color: #666; margin-top: 2px;">Tamanho: {{size}}</span>
                                    </div>
                                </div>
                                <span class="item-price" style="font-weight: 600; color: #333;">R$ {{price}}</span>
                            </div>
                        {{else}}
                            <div style="padding: 10px; color: #777; font-style: italic;">
                                Detalhes dos itens não disponíveis para este pedido.
                            </div>
                        {{/each}}
                    </div>

                    <!-- Footer / Actions -->
                    <div class="order-footer">
                        <div class="order-calculations" style="padding: 15px 0; border-top: 2px solid #eee; margin-top: 10px;">
                            {{#if couponCode}}
                                <div style="display: flex; justify-content: space-between; color: #666; margin-bottom: 5px; font-size: 0.9rem;">
                                    <span>Subtotal:</span>
                                    <span>R$ {{totalAmount}}</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; color: #2e7d32; margin-bottom: 10px; font-size: 0.95rem; font-weight: 500;">
                                    <span>
                                        <i class="fas fa-tag"></i> Cupom ({{couponCode}}):
                                    </span>
                                    <span>- R$ {{discountAmount}}</span>
                                </div>
                            {{/if}}
                            
                            <div class="order-total" style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="font-size: 1.1rem; color: #555;">Total do Pedido:</span>
                                <span class="total-price" style="font-size: 1.3rem; font-weight: 700; color: #000;">R$ {{finalAmount}}</span>
                            </div>
                        </div>
                        
                        <div class="order-actions" style="margin-top: 10px;">
                            {{#if (eq status 'pending')}}
                                <div class="payment-help-box" style="background: #fff8e1; border: 1px solid #ffe0b2; padding: 20px; border-radius: 8px; margin-top: 10px;">
                                    <div style="display: flex; align-items: flex-start; gap: 10px; margin-bottom: 15px;">
                                        <i class="fas fa-info-circle" style="color: #f57c00; font-size: 1.2rem; margin-top: 3px;"></i>
                                        <div>
                                            <h4 style="margin: 0 0 5px 0; color: #ef6c00; font-size: 1rem;">Aguardando Confirmação</h4>
                                            <p style="margin: 0; font-size: 0.9rem; color: #666; line-height: 1.4;">
                                                Se você já realizou o pagamento via Pix ou Cartão, clique em <strong>"Já fiz o pagamento"</strong> para validarmos imediatamente.
                                            </p>
                                        </div>
                                    </div>
                                    
                                    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                                         <button onclick="checkStatus('{{id}}')" class="btn-action" style="flex: 1; background: #2e7d32; color: white; justify-content: center; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 8px;">
                                            <i class="fas fa-check-double"></i> Já fiz o pagamento
                                        </button>
                                        
                                        <button onclick="payNow('{{id}}')" class="btn-action" style="flex: 1; background: #0288d1; color: white; justify-content: center; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 8px;">
                                            Pagar Agora <i class="fas fa-arrow-right"></i>
                                        </button>
                                    </div>

                                    <div style="margin-top: 15px; text-align: center; border-top: 1px solid #ffe0b2; padding-top: 10px;">
                                         <button onclick="deleteOrder('{{id}}')" style="background: none; border: none; color: #d32f2f; cursor: pointer; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 5px; opacity: 0.8;">
                                            <i class="fas fa-times"></i> Desistir e cancelar este pedido
                                        </button>
                                    </div>
                                </div>
                            {{/if}}
                            
                            {{#if (eq status 'rejected')}}
                                <div style="background: #ffebee; color: #c62828; padding: 15px; border-radius: 8px; margin-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                                    <span><i class="fas fa-times-circle"></i> Pagamento recusado ou cancelado.</span>
                                    <button onclick="deleteOrder('{{id}}')" class="btn-action btn-delete" style="background: #ef5350; color: white; border: none; padding: 8px 15px; border-radius: 4px; cursor: pointer;">
                                        <i class="fas fa-trash"></i> Remover
                                    </button>
                                </div>
                            {{/if}}
                            
                            {{#if (eq status 'cancelled')}}
                                <div style="text-align: right; margin-top: 10px;">
                                    <button onclick="deleteOrder('{{id}}')" class="btn-action btn-delete" style="background: #9e9e9e; color: white; border: none; padding: 8px 15px; border-radius: 4px; cursor: pointer;">
                                        <i class="fas fa-trash"></i> Remover do Histórico
                                    </button>
                                </div>
                            {{/if}}

                            {{#if (eq status 'approved')}}
                                <div style="background: #e8f5e9; color: #2e7d32; padding: 15px; border-radius: 8px; margin-top: 10px; text-align: center; font-weight: 600;">
                                    <i class="fas fa-check-circle"></i> Pedido Pago e Confirmado!
                                </div>
                            {{/if}}
                        </div>
                    </div>
                </div>
            {{/each}}
        </div>
        {{#if hasPagination}}
        <div class="orders-pagination">
            {{#if hasPrev}}
            <a href="/meus-pedidos?page={{prevPage}}" class="page-link">« Anterior</a>
            {{/if}}
            <span class="page-info">Página {{currentPage}} de {{totalPages}}</span>
            {{#if hasNext}}
            <a href="/meus-pedidos?page={{nextPage}}" class="page-link">Próxima »</a>
            {{/if}}
        </div>
        {{/if}}
    {{else}}
        <div style="text-align: center; padding: 60px 20px; background: #fff; border-radius: 12px; border: 1px dashed #ddd;">
            <i class="fas fa-shopping-bag" style="font-size: 4rem; color: #eee; margin-bottom: 20px;"></i>
            <h3 style="color: #555; margin-bottom: 10px;">Nenhum pedido encontrado</h3>
            <p style="color: #888; margin-bottom: 25px;">Você ainda não realizou nenhuma compra conosco.</p>
            <a href="/" class="btn-shop">
                Começar a Comprar
            </a>
        </div>
    {{/if}}
</div>

<script>
// Format dates on load
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.order-date').forEach(el => {
        const dateStr = el.innerText;
        const date = new Date(dateStr);
        if(!isNaN(date)) {
            el.innerText = date.toLocaleDateString('pt-BR', { 
                day: '2-digit', month: 'long', year: 'numeric', 
                hour: '2-digit', minute: '2-digit' 
            });
        }
    });
});

async function checkStatus(orderId) {
    const btn = event.currentTarget;
    const originalContent = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
    btn.disabled = true;

    try {
        const response = await fetch(`/api/check-payment/${orderId}`);
        const data = await response.json();

        if (data.status === 'approved') {
            alert('Pagamento APROVADO! O pedido foi atualizado.');
            location.reload();
        } else if (data.status === 'rejected') {
            alert('Pagamento REJEITADO. O status foi atualizado.');
            location.reload();
        } else {
            alert('Pagamento ainda não identificado. Se já pagou, aguarde alguns instantes.');
        }
    } catch (error) {
        console.error(error);
        alert('Erro ao verificar status.');
    } finally {
        btn.innerHTML = originalContent;
        btn.disabled = false;
    }
}

async function payNow(orderId) {
    const btn = event.currentTarget;
    const originalContent = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Carregando...';
    btn.disabled = true;

    try {
        const response = await fetch(`/api/continue-payment/${orderId}`, {
            method: 'POST'
        });
        const data = await response.json();
        
        if (data.init_point) {
            window.location.href = data.init_point;
        } else {
            alert(data.error || 'Erro ao gerar link de pagamento.');
            btn.innerHTML = originalContent;
            btn.disabled = false;
        }
    } catch (error) {
        console.error(error);
        alert('Erro de conexão.');
        btn.innerHTML = originalContent;
        btn.disabled = false;
    }
}

async function deleteOrder(orderId) {
    if (!confirm('Tem certeza que deseja cancelar/excluir este pedido?')) return;

    try {
        const response = await fetch(`/orders/${orderId}/delete`, {
            method: 'POST'
        });
        
        if (response.ok) {
            location.reload();
        } else {
            const data = await response.json();
            alert(data.error || 'Erro ao excluir pedido.');
        }
    } catch (error) {
        console.error(error);
        alert('Erro ao excluir pedido.');
    }
}
</script>


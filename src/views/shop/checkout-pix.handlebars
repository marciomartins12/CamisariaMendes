<div class="pix-page">
    <header class="pix-header">
        <h1 style="font-size: 1.8rem; margin: 0;">Pagamento via Pix - Pedido #{{order.id}}</h1>
        <a href="/meus-pedidos" style="color: #666; text-decoration: none; font-size: 0.9rem;">
            <i class="fas fa-arrow-left"></i> Voltar para meus pedidos
        </a>
    </header>

    <div class="pix-top-grid">
        <div style="background:#fff; padding:20px; border-radius:12px; border:1px solid #eee;">
            <h3 style="margin-top:0; margin-bottom:10px;">Resumo do Pedido</h3>
            <p style="margin: 4px 0; color: #555;">Pedido #{{order.id}}</p>
            <p style="margin: 4px 0; color: #555;">Nome: {{order.customerName}}</p>
            <p style="margin: 4px 0; color: #555;">E-mail: {{order.customerEmail}}</p>
            <p style="margin: 4px 0; color: #555;">Telefone: {{order.customerPhone}}</p>

            <div style="border-top: 1px solid #eee; margin-top: 15px; padding-top: 10px;">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <span style="color:#666;">Total do pedido</span>
                    <strong style="font-size:1.3rem;">R$ {{order.finalAmount}}</strong>
                </div>
            </div>
        </div>

        <div id="status-card" style="background:#fff; padding:20px; border-radius:12px; border:1px solid #eee; text-align:left;">
            <h3 style="margin-top:0; margin-bottom:10px;">Status do pagamento</h3>
            <p id="payment-status-text" style="color:#e69b00; margin-bottom:10px; font-weight:600;">
                {{#if (eq initialStatus 'approved')}}Pagamento aprovado!{{else}}Aguardando pagamento Pix...{{/if}}
            </p>
            <p id="payment-status-helper" style="color:#777; font-size:0.9rem; margin-bottom:16px;">
                {{#if (eq initialStatus 'approved')}}
                Seu pagamento já foi confirmado. Você pode visualizar os detalhes nos seus pedidos.
                {{else}}
                Assim que o pagamento for confirmado pelo banco, esta página será atualizada automaticamente.
                {{/if}}
            </p>
            <div style="font-size:0.85rem; color:#999;">
                <p style="margin:0 0 4px;">1. Abra o aplicativo do seu banco.</p>
                <p style="margin:0 0 4px;">2. Escolha pagar com Pix.</p>
                <p style="margin:0;">3. Escaneie o QR Code ou cole o código Pix.</p>
            </div>
            <button id="btn-view-orders" type="button" onclick="window.location.href='/meus-pedidos'" style="margin-top:16px; padding:10px 20px; border:none; border-radius:8px; background:#111; color:#fff; font-weight:600; cursor:pointer; display:none; width:100%;">
                Ver meus pedidos
            </button>
        </div>
    </div>

    <div id="pix-info" style="background:linear-gradient(135deg,#009ee3 0%,#006fb3 100%); padding:24px 20px; border-radius:16px; border:1px solid #0080c0; margin-bottom:20px; color:#fff;">
        <div class="pix-main-row">
            <div class="pix-main-column">
                <h3 style="margin-top:0; margin-bottom:10px; font-size:1.3rem;">Finalize o pagamento Pix</h3>
                <p style="font-size:0.95rem; margin-bottom:10px; color:rgba(255,255,255,0.9);">
                    Escaneie o QR Code ao lado com o aplicativo do seu banco ou copie o código Pix para pagar.
                </p>
                <p style="font-size:0.85rem; margin-bottom:12px; color:rgba(255,255,255,0.85);">
                    Assim que o banco confirmar o pagamento, vamos atualizar o status deste pedido automaticamente.
                </p>
                <p id="pix-expiration" style="font-size:0.8rem; color:rgba(255,255,255,0.8); margin-bottom:14px;"></p>
                <div style="background:rgba(0,0,0,0.12); border-radius:10px; padding:10px 12px;">
                    <label for="pix-code" style="display:block; font-size:0.85rem; margin-bottom:5px; color:#f5f5f5;">Código Pix (copiar e colar)</label>
                    <textarea id="pix-code" readonly style="width:100%; min-height:70px; border-radius:8px; border:none; padding:8px; font-size:0.85rem; resize:vertical; outline:none;"></textarea>
                    <button type="button" id="btn-copy-pix" style="margin-top:8px; padding:9px 14px; border:none; border-radius:8px; background:#ffffff; color:#006fb3; font-weight:600; cursor:pointer; font-size:0.9rem;">
                        Copiar código Pix
                    </button>
                </div>
                <div id="pix-ticket-wrapper" style="margin-top:10px; display:none;">
                    <a id="pix-ticket-link" href="#" target="_blank" style="font-size:0.8rem; color:#e0f2ff; text-decoration:underline;">
                        Ver detalhes do pagamento no site do Mercado Pago
                    </a>
                </div>
            </div>

            <div class="pix-qr-column">
                <div style="background:#fff; border-radius:16px; padding:14px; display:inline-block; box-shadow:0 8px 16px rgba(0,0,0,0.18);">
                    <p style="margin:0 0 6px; font-size:0.8rem; color:#333;">QR Code Pix</p>
                    <img id="pix-qr-image" src="" alt="QR Code Pix" style="max-width:220px; background:#fff; border-radius:8px; display:none;">
                </div>
            </div>
        </div>
    </div>

    <div id="pix-data"
         data-qr="{{#if pix}}{{pix.qr_code}}{{/if}}"
         data-qr-base64="{{#if pix}}{{pix.qr_code_base64}}{{/if}}"
         data-ticket-url="{{#if pix}}{{pix.ticket_url}}{{/if}}"
         data-expiration="{{#if pix}}{{pix.expiration_date}}{{/if}}">
    </div>

    <div id="payment-success-modal" style="position:fixed; inset:0; background:rgba(0,0,0,0.65); display:none; align-items:center; justify-content:center; z-index:9999;">
        <div style="background:#ffffff; border-radius:18px; max-width:420px; width:90%; padding:24px 22px; text-align:center; box-shadow:0 16px 40px rgba(0,0,0,0.28);">
            <div style="width:70px; height:70px; border-radius:50%; margin:0 auto 14px; background:#e6f8f0; display:flex; align-items:center; justify-content:center;">
                <span style="display:inline-block; width:38px; height:38px; border-radius:50%; background:#00a650; color:#fff; font-size:26px; line-height:38px;">✓</span>
            </div>
            <h2 style="margin:0 0 8px; font-size:1.4rem; color:#111;">Pagamento confirmado!</h2>
            <p style="margin:0 0 4px; font-size:0.95rem; color:#555;">
                Recebemos o seu pagamento Pix com sucesso.
            </p>
            <p style="margin:0 0 18px; font-size:0.85rem; color:#777;">
                Seu pedido #{{order.id}} já está sendo processado. Você pode acompanhar todos os detalhes na página de Meus pedidos.
            </p>
            <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
                <button type="button" onclick="window.location.href='/meus-pedidos'" style="flex:1 1 140px; padding:10px 16px; border:none; border-radius:8px; background:#111; color:#fff; font-weight:600; cursor:pointer;">
                    Ver meus pedidos
                </button>
                <button type="button" id="btn-close-success-modal" style="flex:1 1 120px; padding:10px 16px; border:1px solid #ddd; border-radius:8px; background:#fff; color:#333; font-weight:500; cursor:pointer;">
                    Fechar
                </button>
            </div>
        </div>
    </div>
    <style>
        .pix-page {
            max-width: 900px;
            margin: 0 auto;
            padding: 20px;
        }

        .pix-header {
            margin-bottom: 30px;
            border-bottom: 1px solid #eee;
            padding-bottom: 20px;
        }

        .pix-top-grid {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 20px;
        }

        .pix-main-row {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .pix-main-column {
            flex: 1 1 260px;
            min-width: 0;
        }

        .pix-qr-column {
            flex: 0 0 260px;
            text-align: center;
        }

        @media (min-width: 768px) {
            .pix-top-grid {
                display: grid;
                grid-template-columns: minmax(0, 2fr) minmax(0, 1.5fr);
                gap: 20px;
                align-items: flex-start;
            }

            .pix-main-row {
                flex-direction: row;
                align-items: center;
                justify-content: space-between;
            }
        }
    </style>
</div>

<script>
    function initPixPage() {
        const pixDataEl = document.getElementById('pix-data');
        const img = document.getElementById('pix-qr-image');
        const codeEl = document.getElementById('pix-code');
        const expirationEl = document.getElementById('pix-expiration');
        const ticketWrapper = document.getElementById('pix-ticket-wrapper');
        const ticketLink = document.getElementById('pix-ticket-link');
        const btnCopy = document.getElementById('btn-copy-pix');
        const btnViewOrders = document.getElementById('btn-view-orders');
        const statusText = document.getElementById('payment-status-text');
        const statusHelper = document.getElementById('payment-status-helper');
        const successModal = document.getElementById('payment-success-modal');
        const closeSuccessModalBtn = document.getElementById('btn-close-success-modal');
        let cartCleared = false;

        const qr = pixDataEl ? pixDataEl.getAttribute('data-qr') || '' : '';
        const qrBase64 = pixDataEl ? pixDataEl.getAttribute('data-qr-base64') || '' : '';
        const ticketUrl = pixDataEl ? pixDataEl.getAttribute('data-ticket-url') || '' : '';
        const expiration = pixDataEl ? pixDataEl.getAttribute('data-expiration') || '' : '';

        if (qrBase64) {
            img.src = 'data:image/png;base64,' + qrBase64;
            img.style.display = 'block';
        }

        if (qr) {
            codeEl.value = qr;
        }

        if (expiration) {
            expirationEl.innerText = 'Este código Pix expira em: ' + expiration;
        }

        if (ticketUrl) {
            ticketWrapper.style.display = 'block';
            ticketLink.href = ticketUrl;
        }

        btnCopy.addEventListener('click', function () {
            if (!codeEl.value) return;
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(codeEl.value).then(function () {
                    alert('Código Pix copiado para a área de transferência.');
                }).catch(function () {
                    codeEl.select();
                    document.execCommand('copy');
                    alert('Código Pix copiado para a área de transferência.');
                });
            } else {
                codeEl.select();
                document.execCommand('copy');
                alert('Código Pix copiado para a área de transferência.');
            }
        });

        const orderId = '{{order.id}}';
        let currentStatus = '{{initialStatus}}';

        if (currentStatus === 'approved') {
            btnViewOrders.style.display = 'inline-block';
            if (successModal) {
                successModal.style.display = 'flex';
            }
            if (!cartCleared) {
                try {
                    localStorage.removeItem('camisaria_cart');
                    localStorage.removeItem('camisaria_coupon');
                } catch (e) {}
                cartCleared = true;
            }
            return;
        }

        function updateStatusUI(newStatus) {
            if (newStatus === 'approved') {
                statusText.innerText = 'Pagamento aprovado!';
                statusHelper.innerText = 'Seu pagamento já foi confirmado. Você pode visualizar os detalhes nos seus pedidos.';
                btnViewOrders.style.display = 'inline-block';
                if (successModal) {
                    successModal.style.display = 'flex';
                }
                if (!cartCleared) {
                    try {
                        localStorage.removeItem('camisaria_cart');
                        localStorage.removeItem('camisaria_coupon');
                    } catch (e) {}
                    cartCleared = true;
                }
            } else {
                statusText.innerText = 'Aguardando pagamento Pix...';
                statusHelper.innerText = 'Assim que o pagamento for confirmado pelo banco, esta página será atualizada automaticamente.';
            }
        }

        updateStatusUI(currentStatus);

        let attempts = 0;
        const maxAttempts = 60;

        const intervalId = setInterval(function () {
            attempts++;
            if (attempts > maxAttempts) {
                clearInterval(intervalId);
                return;
            }

            fetch('/api/check-payment/' + orderId)
                .then(function (resp) { return resp.json(); })
                .then(function (data) {
                    if (!data || !data.status) return;

                    currentStatus = data.status;
                    updateStatusUI(currentStatus);

                    if (currentStatus === 'approved') {
                        clearInterval(intervalId);
                    }
                })
                .catch(function (error) {
                    console.error('Erro ao verificar status do pagamento:', error);
                });
        }, 8000);

        if (closeSuccessModalBtn && successModal) {
            closeSuccessModalBtn.addEventListener('click', function () {
                successModal.style.display = 'none';
            });
        }
    }

    document.addEventListener('DOMContentLoaded', initPixPage);
</script>

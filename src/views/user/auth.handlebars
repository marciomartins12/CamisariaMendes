        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        background: linear-gradient(135deg, var(--primary-blue, #0047AB), var(--primary-dark, #002e70));
        border: none;
        color: white;
        box-shadow: 0 10px 20px rgba(0, 71, 171, 0.25);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);

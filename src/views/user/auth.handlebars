<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-header-icon" style="background: transparent; box-shadow: none; width: auto; height: 120px; max-width: 280px; border-radius: 0;">
                <img src="/images/logoSemFundo.png" alt="Camisaria Mendes" style="width: 100%; height: 100%; object-fit: contain;">
            </div>
            <h2>Camisaria Mendes</h2>
            <p>Identifique-se para acessar a campanha</p>
        </div>

        <div class="auth-tabs">
            <button class="tab-btn {{#if (eq activeTab 'register')}}{{else}}active{{/if}}" onclick="switchTab('login')">Entrar</button>
            <button class="tab-btn {{#if (eq activeTab 'register')}}active{{/if}}" onclick="switchTab('register')">Cadastrar</button>
        </div>

        <div class="auth-content">
            <!-- Login Form -->
            <form id="login-form" action="/auth/login" method="POST" class="auth-form {{#if (eq activeTab 'register')}}hidden{{/if}}">
                {{#if campaignCode}}
                <input type="hidden" name="campaignCode" value="{{campaignCode}}">
                {{/if}}
                
                {{#if error}}
                {{#if (eq activeTab 'login')}}
                <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> {{error}}</div>
                {{else}}
                 {{#unless activeTab}}<div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> {{error}}</div>{{/unless}}
                {{/if}}
                {{/if}}

                <div class="form-group">
                    <label>E-mail</label>
                    <div class="input-group">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" name="email" class="form-control" required placeholder="seu@email.com">
                    </div>
                </div>
                <div class="form-group">
                    <label>Senha</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="password" class="form-control" required placeholder="Sua senha">
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-block">
                    <i class="fas fa-sign-in-alt"></i> Acessar
                </button>
            </form>

            <!-- Register Form -->
            <form id="register-form" action="/auth/register" method="POST" class="auth-form {{#if (eq activeTab 'register')}}{{else}}hidden{{/if}}">
                {{#if campaignCode}}
                <input type="hidden" name="campaignCode" value="{{campaignCode}}">
                {{/if}}

                {{#if error}}
                {{#if (eq activeTab 'register')}}
                <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> {{error}}</div>
                {{/if}}
                {{/if}}

                <div class="form-group">
                    <label>Nome Completo</label>
                    <div class="input-group">
                        <i class="fas fa-user input-icon"></i>
                        <input type="text" name="name" class="form-control" required placeholder="Seu nome" value="{{oldData.name}}">
                    </div>
                </div>
                <div class="form-group">
                    <label>Telefone / WhatsApp</label>
                    <div class="input-group">
                        <i class="fab fa-whatsapp input-icon"></i>
                        <input type="text" name="phone" class="form-control" placeholder="(00) 00000-0000" value="{{oldData.phone}}">
                    </div>
                </div>
                <div class="form-group">
                    <label>E-mail</label>
                    <div class="input-group">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" name="email" class="form-control" required placeholder="seu@email.com" value="{{oldData.email}}">
                    </div>
                </div>
                <div class="form-group">
                    <label>Senha</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="password" class="form-control" required placeholder="Crie uma senha">
                    </div>
                </div>
                <div class="form-group">
                    <label>Confirmar Senha</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="confirmPassword" class="form-control" required placeholder="Repita a senha">
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-block">
                    <i class="fas fa-user-plus"></i> Criar Conta
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function switchTab(tab) {
        const loginForm = document.getElementById('login-form');
        const registerForm = document.getElementById('register-form');
        const tabs = document.querySelectorAll('.tab-btn');

        if (tab === 'login') {
            loginForm.classList.remove('hidden');
            registerForm.classList.add('hidden');
            tabs[0].classList.add('active');
            tabs[1].classList.remove('active');
        } else {
            loginForm.classList.add('hidden');
            registerForm.classList.remove('hidden');
            tabs[0].classList.remove('active');
            tabs[1].classList.add('active');
        }
    }
</script>

<style>

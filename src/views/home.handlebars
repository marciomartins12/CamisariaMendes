      <div class="hero-buttons">
        <a href="{{whatsappLink}}" target="_blank" class="btn btn-primary">
            <i class="fab fa-whatsapp" style="margin-right: 8px;"></i>
            Fazer Pedido
        </a>
        <a href="#campanha" class="btn btn-outline">Ver Campanhas</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="shirt-composition">
        <div class="shirt-bg-circle"></div>
        <img src="/images/camisaHomePageSection1.png" alt="Camisa personalizada Camisaria Mendes" class="hero-shirt-image">
        <div class="float-tag tag-1">
            <span class="tag-icon">👕</span>
            <span class="tag-text">Personalizado</span>
        </div>
        <div class="float-tag tag-2">
            <span class="tag-icon">🧵</span>
            <span class="tag-text">Vários Tecidos</span>
        </div>
      </div>
    </div>
  </div>
  <div class="custom-shape-divider-bottom-1678901234">
    <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
        <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="shape-fill"></path>
    </svg>
  </div>
</header>

<section class="campaign-section" id="campanha">
    <div class="container campaign-container">
        <div class="campaign-info">
            <span class="section-subtitle reveal-left">Área Restrita</span>
            <h2 class="reveal-left delay-100">Acesse sua <span class="highlight-text">Campanha</span></h2>
            <p class="reveal-left delay-200">Uma campanha é o seu espaço exclusivo para gerenciar pedidos do seu grupo. Aqui, por meio do seu código de acesso, estão centralizadas as escolhas de corte, tamanhos e pagamento de forma simples e organizada.</p>
            
            <ul class="campaign-features">
                <li class="reveal-left delay-300">
                    <div class="feature-icon">🤝</div>
                    <div class="feature-text">
                        <strong>Campanha em grupo</strong>
                        <span>Obtenha seu código de acesso com o líder da campanha.</span>
                    </div>
                </li>
                <li class="reveal-left delay-400">
                    <div class="feature-icon">📊</div>
                    <div class="feature-text">
                        <strong>Visualize seus pedidos</strong>
                        <span>
                            Veja seu histórico em 
                            {{#if user}}
                                <a href="/meus-pedidos">Meus Pedidos</a>.
                            {{else}}
                                <a href="/auth/login">Meus Pedidos</a>.
                            {{/if}}
                        </span>
                    </div>
                </li>
                <li class="reveal-left delay-500">
                    <div class="feature-icon">🚀</div>
                    <div class="feature-text">
                        <strong>Ainda não tem um pedido?</strong>
                        <span><a href="#contato">Fale conosco</a> e inicie sua campanha agora.</span>
                    </div>
                </li>
            </ul>
        </div>

        <div class="campaign-form-wrapper reveal-right">
            <div class="card campaign-card">
                <div class="card-header">
                    <div class="card-icon">🔒</div>
                    <h3>Área Restrita</h3>
                    <p>Esta área é exclusiva para participantes que possuem um código de acesso.</p>
                </div>
                
                <form action="/campanha/entrar" method="POST" class="campaign-form">
                    <div class="input-group">
                        <input type="text" name="codigo" placeholder="Ex: MENDES2026" required class="input-code">
                        <span class="input-icon">#</span>
                    </div>
                    <button type="submit" class="btn btn-secondary btn-block">
                        Acessar Campanha
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </button>
                </form>
                <!-- Espaço para mensagens de erro -->
                {{#if error}}
                <div class="alert alert-danger custom-alert" role="alert">
                    <i class="fas fa-exclamation-circle"></i>
                    <div>{{error}}</div>
                </div>
                <script>
                    document.addEventListener("DOMContentLoaded", function() {
                        const campaignSection = document.getElementById("campanha");
                        if (campaignSection) {
                            campaignSection.scrollIntoView({ behavior: "smooth", block: "center" });
                        }
                    });
                </script>
                {{/if}}
                {{#if messages.error}}
                <div class="alert alert-danger custom-alert" role="alert">
                    <i class="fas fa-exclamation-circle"></i>
                    <div>{{messages.error}}</div>
                </div>
                <script>
                    document.addEventListener("DOMContentLoaded", function() {
                        const campaignSection = document.getElementById("campanha");
                        if (campaignSection) {
                            campaignSection.scrollIntoView({ behavior: "smooth", block: "center" });
                        }
                    });
                </script>
                {{/if}}
            </div>
        </div>
    </div>
</section>

<style>
    .custom-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        background-color: #ffebee;
        color: #c62828;
        border: 2px solid #ef5350;
        border-radius: 8px;
        padding: 1rem;
        margin-top: 1rem;
        font-weight: 600;
        font-size: 1rem;
        box-shadow: 0 4px 6px rgba(239, 83, 80, 0.2);
        animation: slideIn 0.3s ease-out;
    }

    .custom-alert i {
        font-size: 1.25rem;
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<section class="how-it-works" id="como-funciona">
    <div class="custom-shape-divider-top-how-it-works">
        <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="shape-fill"></path>
        </svg>
    </div>
    <div class="container">
        <div class="section-header">
            <span class="badge-pill">Passo a Passo</span>
            <h2>Como fazer seu pedido?</h2>
            <p>Processo simples e seguro para você garantir sua peça.</p>
        </div>
        
        <div class="process-timeline">
            <!-- Linha de fundo -->
            <div class="timeline-line"></div>

            <!-- Passo 1 -->
            <div class="timeline-step">
                <div class="step-marker">
                    <span class="step-num">1</span>
                </div>
                <div class="step-body">
                    <div class="step-icon">🔐</div>
                    <h3>Acesse</h3>
                    <p>Use o código fornecido pelo líder da campanha.</p>
                </div>
            </div>

            <!-- Passo 2 -->
            <div class="timeline-step">
                <div class="step-marker">
                    <span class="step-num">2</span>
                </div>
                <div class="step-body">
                    <div class="step-icon">👕</div>
                    <h3>Escolha</h3>
                    <p>Selecione o modelo, cor e tamanho ideal.</p>
                </div>
            </div>

            <!-- Passo 3 -->
            <div class="timeline-step">
                <div class="step-marker">
                    <span class="step-num">3</span>
                </div>
                <div class="step-body">
                    <div class="step-icon">💳</div>
                    <h3>Pague</h3>
                    <p>Pagamento seguro via Pix ou Cartão.</p>
                </div>
            </div>

            <!-- Passo 4 -->
            <div class="timeline-step">
                <div class="step-marker">
                    <span class="step-num">4</span>
                </div>
                <div class="step-body">
                    <div class="step-icon">📦</div>
                    <h3>Receba</h3>
                    <p>Aguarde o prazo final da sua campanha.</p>
                </div>
            </div>
        </div>
        
        <div class="cta-wrapper">
             <div class="cta-decoration-blob"></div>
             <a href="#campanha" class="btn btn-primary btn-lg">Começar Agora</a>
        </div>
    </div>
</section>

<a href="{{whatsappLink}}" target="_blank" class="whatsapp-float" aria-label="WhatsApp">
    <i class="fab fa-whatsapp"></i>
</a>


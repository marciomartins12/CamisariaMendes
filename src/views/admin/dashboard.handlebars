<div class="admin-layout">
    {{> admin-sidebar}}

    <main class="admin-main-content">
        <div class="dashboard-header">
            <h2>Bem-vindo, {{admin.username}}!</h2>
            <p>Visão geral do sistema</p>
        </div>

        <div class="dashboard-stats">
            <div class="stat-card">
                <div class="stat-icon campaign">
                    <i class="fas fa-bullhorn"></i>
                </div>
                <div class="stat-info">
                    <h3>{{campaignCount}}</h3>
                    <p>Campanhas Ativas</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon users">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-info">
                    <h3>Admin</h3>
                    <p>Perfil</p>
                </div>
            </div>
        </div>

        <div class="recent-activity">
            <h3>Acesso Rápido</h3>
            <div class="quick-actions">
                <a href="/admin/campanhas/nova" class="btn btn-primary">Nova Campanha</a>
                <a href="/admin/perfil" class="btn btn-outline">Editar Perfil</a>
            </div>
        </div>
    </main>
</div>
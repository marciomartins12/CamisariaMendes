<div class="admin-layout">
    {{> admin-sidebar}}

    <main class="admin-main-content">
        <div class="dashboard-header-compact">
            <div class="header-title">
                <h2>Administradores</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Administradores</li>
                    </ol>
                </nav>
            </div>
            <a href="/admin/usuarios/novo" class="btn btn-primary">
                <i class="fas fa-plus"></i> Novo Administrador
            </a>
        </div>

        {{#if success}}
        <div class="alert alert-success">{{success}}</div>
        {{/if}}

        {{#if error}}
        <div class="alert alert-danger">{{error}}</div>
        {{/if}}

        <div class="campaigns-container">
            <div class="campaigns-list">
                {{#if admins.length}}
                <div class="table-responsive">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Usuário</th>
                                <th>E-mail</th>
                                <th>Papel</th>
                                <th>Criado em</th>
                                <th style="text-align: right;">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each admins}}
                            <tr>
                                <td>{{this.username}}</td>
                                <td>{{this.email}}</td>
                                <td>
                                    {{#if (eq this.role 'superadmin')}}Super Admin{{else}}Admin{{/if}}
                                </td>
                                <td>{{formatDate this.createdAt}}</td>
                                <td style="text-align: right;">
                                    <div class="action-buttons">
                                        <a href="/admin/usuarios/editar/{{this.id}}" class="btn-icon edit" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form action="/admin/usuarios/deletar/{{this.id}}" method="POST" style="display: inline;" onsubmit="return confirm('Tem certeza que deseja excluir este administrador?');">
                                            <button type="submit" class="btn-icon delete" title="Excluir">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
                {{else}}
                    <div class="empty-state">
                        <div class="empty-icon"><i class="fas fa-users-cog"></i></div>
                        <h3>Nenhum administrador cadastrado</h3>
                        <p>Comece criando o primeiro administrador do sistema.</p>
                        <a href="/admin/usuarios/novo" class="btn btn-primary">Criar Administrador</a>
                    </div>
                {{/if}}
            </div>
        </div>
    </main>
</div>


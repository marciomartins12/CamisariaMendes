<div class="admin-layout">
    {{> admin-sidebar}}

    <main class="admin-main-content">
        <!-- Compact Header -->
        <div class="dashboard-header-compact">
            <div class="header-title">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <h2 style="margin: 0;">
                        <span class="badge badge-secondary" style="font-size: 0.7em; vertical-align: middle; margin-right: 8px; background-color: #6c757d; color: white; border-radius: 4px;">{{campaign.formattedId}}</span>
                        {{campaign.title}}
                    </h2>
                </div>
                <ul class="breadcrumb" style="margin-top: 5px;">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/admin/campanhas">Campanhas</a></li>
                    <li class="breadcrumb-item active">Detalhes</li>
                </ul>
            </div>
            <div class="header-actions">
                <a href="/admin/campanhas/editar/{{campaign.id}}" class="btn btn-primary">
                    <i class="fas fa-edit"></i> Editar Campanha
                </a>
            </div>
        </div>

        {{#if success}}
        <div class="alert alert-success">{{success}}</div>
        {{/if}}

        <!-- Campaign Stats Row -->
        <div class="details-stats-grid">
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper blue">
                    <i class="fas fa-tshirt"></i>
                </div>
                <div class="stat-content">
                    <h4>Produtos</h4>
                    <div class="value">{{campaign.shirts.length}}</div>
                </div>
            </div>
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper green">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <div class="stat-content">
                    <h4>Pedidos</h4>
                    <div class="value">{{campaign.totalOrders}}</div>
                </div>
            </div>
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper purple">
                    <i class="fas fa-dollar-sign"></i>
                </div>
                <div class="stat-content">
                    <h4>Arrecadado</h4>
                    <div class="value">R$ {{campaign.totalRevenueFormatted}}</div>
                    <div class="value" style="font-size:0.9rem; color:#64748b;">Líquido: R$ {{campaign.totalNetRevenueFormatted}}</div>
                    <div style="font-size:0.8rem; color:#94a3b8; margin-top:4px;">
                        Líquido com taxas do Mercado Pago já descontadas por pedido.
                    </div>
                </div>
            </div>
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper orange">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-content">
                    <h4>Dias Restantes</h4>
                    <div class="value">{{campaign.daysRemaining}}</div>
                </div>
            </div>
        </div>

        <div class="details-info-row">
            <!-- General Info Card -->
            <div class="details-card">
                <div class="card-header">
                    <h3><i class="fas fa-info-circle"></i> Informações Gerais</h3>
                    <span class="badge badge-{{campaign.status}}">
                        {{#if (eq campaign.status 'active')}}Ativa{{/if}}
                        {{#if (eq campaign.status 'inactive')}}Inativa{{/if}}
                    </span>
                </div>
                <div class="card-body">
                    <div class="details-data-grid">
                        <!-- Description -->
                        <div class="data-item full-width">
                            <div class="data-icon purple">
                                <i class="fas fa-align-left"></i>
                            </div>
                            <div class="data-content">
                                <span class="data-label">Descrição</span>
                                <span class="data-value">{{campaign.description}}</span>
                            </div>
                        </div>

                        <!-- Date -->
                        <div class="data-item">
                            <div class="data-icon blue">
                                <i class="far fa-calendar-alt"></i>
                            </div>
                            <div class="data-content">
                                <span class="data-label">Período</span>
                                <span class="data-value">{{formatDate campaign.startDate}} - {{formatDate campaign.endDate}}</span>
                            </div>
                        </div>

                        <!-- Created At -->
                        <div class="data-item">
                            <div class="data-icon orange">
                                <i class="far fa-clock"></i>
                            </div>
                            <div class="data-content">
                                <span class="data-label">Criada em</span>
                                <span class="data-value">{{formatDate campaign.createdAt}}</span>
                            </div>
                        </div>

                        <!-- Access Code -->
                        <div class="data-item full-width">
                            <div class="data-icon green">
                                <i class="fas fa-key"></i>
                            </div>
                            <div class="data-content">
                                <span class="data-label">Código de Acesso</span>
                                <div class="data-value" style="display: flex; align-items: center; gap: 10px;">
                                    <code style="background: #f1f5f9; padding: 4px 10px; border-radius: 8px; border: 1px solid #e2e8f0; font-family: monospace; color: #475569; font-weight: 700; font-size: 1.1rem;">{{campaign.accessCode}}</code>
                                    <button class="copy-btn" onclick="copyToClipboard('{{campaign.accessCode}}')" title="Copiar Código">
                                        <i class="far fa-copy"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Campaign Leader Info Card -->
            <div class="details-card">
                <div class="card-header">
                    <h3><i class="fas fa-user-tie"></i> Dados do Líder da Campanha</h3>
                </div>
                <div class="card-body">
                    <div class="details-data-grid" style="grid-template-columns: 1fr;">
                        <div class="data-item">
                            <div class="data-icon blue">
                                <i class="fas fa-user"></i>
                            </div>
                            <div class="data-content">
                                <span class="data-label">Nome</span>
                                <span class="data-value">{{campaign.clientName}}</span>
                            </div>
                        </div>
                        
                        <div class="data-item">
                            <div class="data-icon green">
                                <i class="fas fa-phone"></i>
                            </div>
                            <div class="data-content">
                                <span class="data-label">Telefone</span>
                                <span class="data-value">{{campaign.clientPhone}}</span>
                            </div>
                        </div>

                        <div class="data-item">
                            <div class="data-icon pink">
                                <i class="fab fa-instagram"></i>
                            </div>
                            <div class="data-content">
                                <span class="data-label">Instagram</span>
                                <span class="data-value">
                                    {{#if campaign.clientInstagram}}
                                    <a href="https://instagram.com/{{campaign.clientInstagram}}" target="_blank" style="color: #d62976; text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 5px;">
                                        @{{campaign.clientInstagram}} <i class="fas fa-external-link-alt" style="font-size: 0.7rem;"></i>
                                    </a>
                                    {{else}}
                                    <span style="color: #94a3b8;">Não informado</span>
                                    {{/if}}
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions / Export -->
            <div class="details-card">
                <div class="card-header">
                    <h3><i class="fas fa-bolt"></i> Ações Rápidas</h3>
                </div>
                <div class="card-body">
                    <div class="quick-actions-grid">
                        <button class="action-tile-btn word" id="btnExportWord">
                            <i class="fas fa-file-word"></i>
                            <span>Exportar Pedidos</span>
                        </button>
                        <button 
                            class="action-tile-btn share" 
                            data-share-url="/c/{{campaign.accessCode}}"
                            data-campaign-title="{{campaign.title}}"
                            data-campaign-leader="{{campaign.clientName}}"
                            data-campaign-description="{{campaign.description}}"
                        >
                            <i class="fas fa-share-alt"></i>
                            <span>Compartilhar Link</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Sales Summary -->
            <div class="details-card">
                <div class="card-header">
                    <h3><i class="fas fa-chart-pie"></i> Resumo de Vendas</h3>
                </div>
                <div class="card-body">
                    <div class="sales-summary-list">
                        {{#if salesSummary}}
                            {{#each salesSummary}}
                            <div class="sales-summary-item">
                                <div class="sales-item-header">
                                    <span class="sales-item-name">{{#if this.baseName}}{{this.baseName}}{{else}}{{@key}}{{/if}}</span>
                                    <span class="sales-item-type badge badge-info">{{this.type}}</span>
                                    {{#if this.color}}
                                    <span class="sales-item-color" style="margin-left: 10px; font-weight: 500; color: #64748b; font-size: 0.9rem;">
                                        <i class="fas fa-palette" style="margin-right: 4px; color: #94a3b8;"></i> {{#if (eq (typeof this.color) 'object')}}{{join this.color ', '}}{{else}}{{this.color}}{{/if}}
                                    </span>
                                    {{/if}}
                                </div>
                                <div class="sales-item-stats">
                                    <div class="sales-total">
                                        <span class="label">Total:</span>
                                        <span class="value">{{this.total}}</span>
                                    </div>
                                    <div class="sales-sizes">
                                        {{#each this.sizes}}
                                        <span class="size-badge">{{@key}}: {{this}}</span>
                                        {{/each}}
                                    </div>
                                </div>
                            </div>
                            {{/each}}
                        {{else}}
                            <p class="text-muted">Nenhuma venda registrada.</p>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>

        <div class="details-card">
            <div class="card-header">
                <h3><i class="fas fa-tshirt"></i> Produtos Disponíveis</h3>
                <button 
                    type="button" 
                    class="btn-mini btn-add-product" 
                    id="addProductBtn"
                    data-campaign-id="{{campaign.id}}"
                >
                    <i class="fas fa-plus"></i>
                    <span>Novo produto</span>
                </button>
            </div>
            <div class="card-body">
                <div class="products-grid-mini">
                    {{#each campaign.shirts}}
                    <div class="mini-product-card">
                        <div class="mini-product-image-wrapper" data-images='{{json this.images}}' data-index="0">
                            {{#if this.images.[0]}}
                                <img src="{{this.images.[0]}}" alt="{{this.name}}" class="mini-product-image">
                                {{#if this.images.[1]}}
                                <div class="mini-product-multi">
                                    <span class="multi-count">{{this.images.length}} fotos</span>
                                </div>
                                <button type="button" class="mini-image-nav prev"><i class="fas fa-chevron-left"></i></button>
                                <button type="button" class="mini-image-nav next"><i class="fas fa-chevron-right"></i></button>
                                {{/if}}
                            {{else}}
                                <div class="mini-product-placeholder">
                                    <i class="fas fa-tshirt"></i>
                                </div>
                            {{/if}}
                            <div class="product-price-badge">
                                R$ {{this.price}}
                            </div>
                        </div>
                        
                        <div class="mini-product-details">
                            <h4 class="mini-product-title" title="{{this.name}}">{{this.name}}</h4>
                            
                            <div class="mini-product-specs">
                                <div class="spec-item">
                                    <i class="fas fa-tag"></i> <span>{{this.type}}</span>
                                </div>
                                <div class="spec-item">
                                    <i class="fas fa-palette"></i> <span>{{#if this.color}}{{join this.color ', '}}{{else}}-{{/if}}</span>
                                </div>
                            </div>

                            <div class="mini-product-sizes">
                                {{#each (split this.sizes ',')}}
                                <span class="size-pill">{{this}}</span>
                                {{/each}}
                            </div>
                        </div>

                        <div class="mini-product-actions">
                            <a 
                                href="/admin/campanhas/detalhes/{{../campaign.id}}?editShirt={{this.id}}" 
                                class="btn-mini btn-edit-product"
                            >
                                <i class="fas fa-pen-to-square"></i>
                                <span>Editar</span>
                            </a>
                            <form action="/admin/campanhas/{{../campaign.id}}/camisas/deletar/{{this.id}}" method="POST" class="inline-delete" onsubmit="return confirm('Deseja realmente apagar este modelo?');">
                                <button type="submit" class="btn-mini delete">
                                    <i class="fas fa-trash"></i>
                                    <span>Apagar</span>
                                </button>
                            </form>
                        </div>
                    </div>
                    {{/each}}
                </div>
            </div>
        </div>

        <div class="details-card">
            <div class="card-header">
                <h3><i class="fas fa-receipt"></i> Pedidos da Campanha</h3>
            </div>
            <div class="card-body">
                {{#if orders.length}}
                <div class="table-responsive">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Data</th>
                                <th>Cliente</th>
                                <th>Contato</th>
                                <th>Valor</th>
                                <th>Status</th>
                                <th>Método</th>
                                <th style="text-align:right;">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each orders}}
                            <tr>
                                <td>#{{this.id}}</td>
                                <td>{{formatDate this.createdAt}}</td>
                                <td>{{this.customerName}}</td>
                                <td>
                                    {{#if this.customerEmail}}<div>{{this.customerEmail}}</div>{{/if}}
                                    {{#if this.customerPhone}}<div>{{this.customerPhone}}</div>{{/if}}
                                </td>
                                <td>R$ {{this.finalAmount}}</td>
                                <td>
                                    <span class="badge badge-{{this.status}}">
                                        {{#if (eq this.status 'approved')}}Aprovado{{/if}}
                                        {{#if (eq this.status 'pending')}}Pendente{{/if}}
                                        {{#if (eq this.status 'rejected')}}Rejeitado{{/if}}
                                        {{#if (eq this.status 'cancelled')}}Cancelado{{/if}}
                                    </span>
                                </td>
                                <td>
                                    {{#if this.paymentMethod}}{{this.paymentMethod}}{{else}}-{{/if}}
                                </td>
                                <td style="text-align:right;">
                                    <div class="action-buttons">
                                        {{#if (eq this.status 'pending')}}
                                        <form action="/admin/pedidos/{{this.id}}/sincronizar" method="POST" style="display:inline;">
                                            <button type="submit" class="btn-icon" title="Checar status no Mercado Pago">
                                                <i class="fas fa-sync-alt"></i>
                                            </button>
                                        </form>
                                        <form action="/admin/pedidos/{{this.id}}/aprovar-manual" method="POST" style="display:inline;" onsubmit="return confirm('Confirmar este pedido como pago manualmente?');">
                                            <button type="submit" class="btn-icon edit" title="Confirmar manualmente">
                                                <i class="fas fa-check-circle"></i>
                                            </button>
                                        </form>
                                        <form action="/admin/pedidos/{{this.id}}/cancelar" method="POST" style="display:inline;" onsubmit="return confirm('Cancelar este pedido?');">
                                            <button type="submit" class="btn-icon delete" title="Cancelar pedido">
                                                <i class="fas fa-times-circle"></i>
                                            </button>
                                        </form>
                                        {{else}}
                                        <span style="font-size:0.8rem; color:#64748b;">Sem ações</span>
                                        {{/if}}
                                    </div>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
                {{else}}
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-receipt"></i></div>
                    <h3>Nenhum pedido encontrado</h3>
                    <p>Os pedidos desta campanha aparecerão aqui conforme forem realizados.</p>
                </div>
                {{/if}}
            </div>
        </div>
    </main>
</div>

<div class="mini-edit-modal-backdrop" id="miniCreateModal">
    <div class="mini-edit-modal">
        <div class="mini-edit-header">
            <h3>Novo produto da campanha</h3>
            <button type="button" class="mini-edit-close">&times;</button>
        </div>
        <form action="/admin/campanhas/{{campaign.id}}/camisas/criar" method="POST" class="admin-form">
            <div class="mini-edit-body">
                <div class="mini-edit-group">
                    <label>Nome do modelo</label>
                    <input type="text" name="name" class="form-control" required placeholder="Ex: Camisa Nova">
                </div>
                <div class="mini-edit-row">
                    <div class="mini-edit-group">
                        <label>Cores disponíveis</label>
                        <input type="text" name="color" class="form-control" placeholder="Ex: Preto, Branco, Azul (separados por vírgula)">
                        <small class="text-muted">Separe as cores por vírgula.</small>
                    </div>
                    <div class="mini-edit-group">
                        <label>Corte</label>
                        <select name="type" class="form-control">
                            <option value="Tradicional">Tradicional</option>
                            <option value="Oversized">Oversized</option>
                            <option value="Cropped">Cropped</option>
                            <option value="Infant">Infant</option>
                        </select>
                    </div>
                </div>
                <div class="mini-edit-row">
                    <div class="mini-edit-group">
                        <label>Preço (R$)</label>
                        <input type="number" step="0.01" name="price" class="form-control" required placeholder="0.00">
                    </div>
                    <div class="mini-edit-group">
                        <label>Tamanhos disponíveis</label>
                        <div class="sizes-wrapper">
                            <input type="hidden" name="sizes" class="mini-sizes-input" value="">
                            <div class="size-options"></div>
                            <small class="text-muted"><i class="fas fa-mouse-pointer"></i> Selecione os tamanhos disponíveis</small>
                        </div>
                    </div>
                </div>
                <div class="mini-edit-group mini-edit-images">
                    <label>Imagens do modelo</label>
                    <div class="mini-edit-images-wrapper">
                        <input type="hidden" name="imagesJSON" class="mini-edit-images-json" value="[]">
                        <input type="file" accept="image/*" class="mini-edit-image-file" style="display:none" onchange="handleMiniImageSelected(this)">
                        <button type="button" class="btn-mini btn-upload-image mini-edit-upload" onclick="triggerMiniImageUpload(this)">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <span>Adicionar imagem</span>
                        </button>
                        <div class="mini-edit-images-grid"></div>
                    </div>
                </div>
            </div>
            <div class="mini-edit-footer">
                <button type="button" class="btn btn-outline mini-edit-close">Cancelar</button>
                <button type="submit" class="btn btn-primary">Adicionar produto</button>
            </div>
        </form>
    </div>
</div>

{{#if editingShirt}}
<div class="mini-edit-modal-backdrop visible" id="miniEditModal">
    <div class="mini-edit-modal">
        <div class="mini-edit-header">
            <h3>Editar produto selecionado</h3>
            <a href="/admin/campanhas/detalhes/{{campaign.id}}" class="mini-edit-close" style="text-decoration:none;">&times;</a>
        </div>
        <form action="/admin/campanhas/{{campaign.id}}/camisas/editar/{{editingShirt.id}}" method="POST" class="admin-form">
            <div class="mini-edit-body">
                <div class="mini-edit-group">
                    <label>Nome do modelo</label>
                    <input type="text" name="name" class="form-control" required value="{{editingShirt.name}}">
                </div>
                <div class="mini-edit-row">
                    <div class="mini-edit-group">
                        <label>Cores disponíveis</label>
                        <input type="text" name="color" class="form-control" value="{{#if editingShirt.color}}{{join editingShirt.color ', '}}{{/if}}" placeholder="Ex: Preto, Branco, Azul">
                        <small class="text-muted">Separe as cores por vírgula.</small>
                    </div>
                    <div class="mini-edit-group">
                        <label>Corte</label>
                        <select name="type" class="form-control">
                            <option value="Tradicional" {{#if (eq editingShirt.type 'Tradicional')}}selected{{/if}}>Tradicional</option>
                            <option value="Oversized" {{#if (eq editingShirt.type 'Oversized')}}selected{{/if}}>Oversized</option>
                            <option value="Cropped" {{#if (eq editingShirt.type 'Cropped')}}selected{{/if}}>Cropped</option>
                            <option value="Infant" {{#if (eq editingShirt.type 'Infant')}}selected{{/if}}>Infant</option>
                        </select>
                    </div>
                </div>
                <div class="mini-edit-row">
                    <div class="mini-edit-group">
                        <label>Preço (R$)</label>
                        <input type="number" step="0.01" name="price" class="form-control" required value="{{editingShirt.price}}">
                    </div>
                    <div class="mini-edit-group">
                        <label>Tamanhos disponíveis</label>
                        <div class="sizes-wrapper">
                            <input type="hidden" name="sizes" class="mini-sizes-input" value="{{editingShirt.sizes}}">
                            <div class="size-options"></div>
                            <small class="text-muted"><i class="fas fa-mouse-pointer"></i> Selecione os tamanhos disponíveis</small>
                        </div>
                    </div>
                </div>
                <div class="mini-edit-group mini-edit-images">
                    <label>Imagens do modelo</label>
                    <div class="mini-edit-images-wrapper">
                        <input type="hidden" name="imagesJSON" class="mini-edit-images-json" value='{{#if editingShirt.images}}{{json editingShirt.images}}{{else}}[]{{/if}}'>
                        <input type="file" accept="image/*" class="mini-edit-image-file" style="display:none" onchange="handleMiniImageSelected(this)">
                        <button type="button" class="btn-mini btn-upload-image mini-edit-upload" onclick="triggerMiniImageUpload(this)">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <span>Adicionar imagem</span>
                        </button>
                        <div class="mini-edit-images-grid"></div>
                    </div>
                </div>
            </div>
            <div class="mini-edit-footer">
                <a href="/admin/campanhas/detalhes/{{campaign.id}}" class="btn btn-outline">Cancelar</a>
                <button type="submit" class="btn btn-primary">Salvar alterações</button>
            </div>
        </form>
    </div>
</div>
{{/if}}

<script>
function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
        alert('Código copiado!');
    });
}

document.addEventListener('DOMContentLoaded', function() {
    const shareBtn = document.querySelector('.action-tile-btn.share');
    if (shareBtn) {
        shareBtn.addEventListener('click', function() {
            const path = shareBtn.getAttribute('data-share-url') || '';
            const url = window.location.origin + path;
            const title = shareBtn.getAttribute('data-campaign-title') || '';
            const leader = shareBtn.getAttribute('data-campaign-leader') || '';
            const description = shareBtn.getAttribute('data-campaign-description') || '';

            let message = '🔒 Compra Exclusiva – ' + title;
            if (leader) {
                message += ' – ' + leader;
            }
            message += ';\n\n';

            if (description) {
                message += description + ';\n\n';
            }

            message += 'Cada integrante pode realizar sua compra individualmente, escolhendo o tamanho e efetuando o pagamento de forma independente.\n\n';
            message += '📸 A produção será iniciada após atingir o tempo limite da campanha personalizada de venda conforme orientado ao líder do pedido.\n\n';
            message += 'Clique no link abaixo para finalizar sua compra:\n\n';
            message += '👉 Comprar minha camisa 🛒\n';
            message += url;
            copyToClipboard(message);
            alert('Mensagem de compartilhamento copiada! Cole no WhatsApp para enviar.');
        });
    }

    const addProductBtn = document.getElementById('addProductBtn');
    const createModal = document.getElementById('miniCreateModal');
    if (addProductBtn && createModal) {
        addProductBtn.addEventListener('click', function() {
            createModal.classList.add('visible');
        });

        const closeButtons = createModal.querySelectorAll('.mini-edit-close');
        closeButtons.forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                createModal.classList.remove('visible');
            });
        });

        createModal.addEventListener('click', function(e) {
            if (e.target === createModal) {
                createModal.classList.remove('visible');
            }
        });
    }

    initMiniGalleries();
    initMiniEditImages();
    initSizeChipsForModals();
});

function initMiniGalleries() {
    const wrappers = document.querySelectorAll('.mini-product-image-wrapper[data-images]');
    wrappers.forEach(wrapper => {
        const raw = wrapper.getAttribute('data-images') || '[]';
        let images = [];
        try {
            images = JSON.parse(raw);
        } catch (e) {
            images = [];
        }
        if (!images || images.length <= 1) return;

        const imgEl = wrapper.querySelector('.mini-product-image');
        if (!imgEl) return;

        let index = 0;
        const prevBtn = wrapper.querySelector('.mini-image-nav.prev');
        const nextBtn = wrapper.querySelector('.mini-image-nav.next');

        const updateImage = () => {
            imgEl.src = images[index];
        };

        if (prevBtn) {
            prevBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                index = (index - 1 + images.length) % images.length;
                updateImage();
            });
        }

        if (nextBtn) {
            nextBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                index = (index + 1) % images.length;
                updateImage();
            });
        }
    });
}

function initMiniEditImages() {
    const wrappers = document.querySelectorAll('.mini-edit-images-wrapper');
    if (!wrappers.length) return;
    wrappers.forEach(function(wrapper) {
        const jsonInput = wrapper.querySelector('.mini-edit-images-json');
        const grid = wrapper.querySelector('.mini-edit-images-grid');
        if (!jsonInput || !grid) return;
        let images = [];
        try {
            images = JSON.parse(jsonInput.value || '[]');
        } catch (e) {
            images = [];
        }
        renderMiniEditImages(grid, jsonInput, images);
    });
}

function renderMiniEditImages(grid, jsonInput, images) {
    grid.innerHTML = '';
    (images || []).forEach(function(src, index) {
        const item = document.createElement('div');
        item.className = 'mini-edit-image-item';
        item.innerHTML = '<img src="' + src + '" class="mini-edit-image-thumb">' +
            '<button type="button" class="mini-edit-image-remove" data-index="' + index + '">&times;</button>';
        grid.appendChild(item);
    });
    jsonInput.value = JSON.stringify(images || []);
}

function triggerMiniImageUpload(btn) {
    const wrapper = btn.closest('.mini-edit-images-wrapper');
    if (!wrapper) return;
    const input = wrapper.querySelector('.mini-edit-image-file');
    if (input) {
        input.click();
    }
}

function handleMiniImageSelected(input) {
    if (!input.files || !input.files.length) return;
    const wrapper = input.closest('.mini-edit-images-wrapper');
    if (!wrapper) return;
    const jsonInput = wrapper.querySelector('.mini-edit-images-json');
    const grid = wrapper.querySelector('.mini-edit-images-grid');
    if (!jsonInput || !grid) return;
    const file = input.files[0];
    if (file.size > 5 * 1024 * 1024) {
        alert('A imagem deve ter no máximo 5MB.');
        input.value = '';
        return;
    }
    const reader = new FileReader();
    reader.onload = function(e) {
        let images = [];
        try {
            images = JSON.parse(jsonInput.value || '[]');
        } catch (err) {
            images = [];
        }
        images.push(e.target.result);
        renderMiniEditImages(grid, jsonInput, images);
        input.value = '';
    };
    reader.readAsDataURL(file);
}

const SIZE_PRESETS = {
    Tradicional: ['P', 'M', 'G', 'GG', 'ExGG', 'P baby look', 'M baby look', 'G baby look'],
    Oversized: ['PP', 'P', 'M', 'G', 'GG', 'XG'],
    Infant: ['2', '4', '6', '8', '10', '12', '14'],
    Default: ['P', 'M', 'G', 'GG', 'XG']
};

function updateMiniSizesInput(container) {
    const chips = container.querySelectorAll('.size-chip.active');
    const values = Array.from(chips).map(c => c.dataset.value);
    const input = container.closest('.sizes-wrapper').querySelector('.mini-sizes-input');
    if (input) {
        input.value = values.join(', ');
    }
}

function applySizePresetForModal(wrapper, currentValue) {
    if (!wrapper) return;
    const card = wrapper.closest('.mini-edit-modal');
    if (!card) return;
    const select = card.querySelector('select[name="type"]');
    if (!select) return;
    const type = select.value || '';
    let preset = SIZE_PRESETS.Default;
    if (type === 'Tradicional') {
        preset = SIZE_PRESETS.Tradicional;
    } else if (type === 'Oversized') {
        preset = SIZE_PRESETS.Oversized;
    } else if (type === 'Infant') {
        preset = SIZE_PRESETS.Infant;
    }
    const sizeOptions = wrapper.querySelector('.size-options');
    if (!sizeOptions) return;
    sizeOptions.innerHTML = '';
    const currentSizes = currentValue ? currentValue.split(',').map(s => s.trim()).filter(Boolean) : [];
    preset.forEach(size => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'size-chip';
        btn.dataset.value = size;
        btn.textContent = size;
        if (!currentSizes.length || currentSizes.includes(size)) {
            btn.classList.add('active');
        }
        sizeOptions.appendChild(btn);
    });
    updateMiniSizesInput(sizeOptions);
}

function initSizeChipsForModals() {
    const wrappers = document.querySelectorAll('.mini-edit-modal .sizes-wrapper');
    if (!wrappers.length) return;

    wrappers.forEach(function(wrapper) {
        const input = wrapper.querySelector('.mini-sizes-input');
        const card = wrapper.closest('.mini-edit-modal');
        if (!input || !card) return;
        applySizePresetForModal(wrapper, input.value);

        const select = card.querySelector('select[name="type"]');
        if (select && !select.dataset.modalSizeEnhanced) {
            select.dataset.modalSizeEnhanced = 'true';
            select.addEventListener('change', function() {
                const w = card.querySelector('.sizes-wrapper');
                if (!w) return;
                const hiddenInput = w.querySelector('.mini-sizes-input');
                if (hiddenInput) {
                    hiddenInput.value = '';
                }
                applySizePresetForModal(w, '');
            });
        }
    });

    document.addEventListener('click', function(e) {
        const chip = e.target.closest('.mini-edit-modal .size-chip');
        if (!chip) return;
        chip.classList.toggle('active');
        const container = chip.parentElement;
        if (container) {
            updateMiniSizesInput(container);
        }
    }, { passive: false });
}

document.addEventListener('click', function(e) {
    const removeBtn = e.target.closest('.mini-edit-image-remove');
    if (!removeBtn) return;
    const wrapper = removeBtn.closest('.mini-edit-images-wrapper');
    if (!wrapper) return;
    const grid = wrapper.querySelector('.mini-edit-images-grid');
    const jsonInput = wrapper.querySelector('.mini-edit-images-json');
    if (!grid || !jsonInput) return;
    let images = [];
    try {
        images = JSON.parse(jsonInput.value || '[]');
    } catch (err) {
        images = [];
    }
    const items = Array.from(grid.querySelectorAll('.mini-edit-image-item'));
    const item = removeBtn.closest('.mini-edit-image-item');
    const index = items.indexOf(item);
    if (index > -1 && index < images.length) {
        images.splice(index, 1);
        renderMiniEditImages(grid, jsonInput, images);
    }
});


document.addEventListener('DOMContentLoaded', function() {
    const exportBtn = document.getElementById('btnExportWord');
    if (exportBtn) {
        exportBtn.addEventListener('click', function() {
            const btn = this;
            const originalContent = btn.innerHTML;
            
            // Disable button and show loading state
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> <span>Gerando arquivo Word, aguarde...</span>';
            
            // Trigger download
            const campaignId = "{{campaign.id}}";
            if (campaignId) {
                window.location.href = `/admin/campanhas/${campaignId}/exportar-word`;
                
                // Reset button after a delay
                setTimeout(() => {
                    btn.innerHTML = '<i class="fas fa-check"></i> <span>Arquivo exportado com sucesso!</span>';
                    setTimeout(() => {
                        btn.disabled = false;
                        btn.innerHTML = originalContent;
                    }, 3000);
                }, 3000);
            } else {
                alert('Erro: ID da campanha não encontrado.');
                btn.disabled = false;
                btn.innerHTML = originalContent;
            }
        });
    }
});


</script>

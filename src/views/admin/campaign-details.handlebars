<div class="admin-layout">
    {{> admin-sidebar}}

    <main class="admin-main-content">
        <!-- Compact Header -->
        <div class="dashboard-header-compact">
            <div class="header-title">
                <h2>{{campaign.title}}</h2>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/admin/campanhas">Campanhas</a></li>
                    <li class="breadcrumb-item active">Detalhes</li>
                </ul>
            </div>
            <div class="header-actions">
                <a href="/admin/campanhas/editar/{{campaign.id}}" class="btn btn-primary">
                    <i class="fas fa-edit"></i> Editar Campanha
                </a>
            </div>
        </div>

        {{#if success}}
        <div class="alert alert-success">{{success}}</div>
        {{/if}}

        <!-- Campaign Stats Row -->
        <div class="details-stats-grid">
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper blue">
                    <i class="fas fa-tshirt"></i>
                </div>
                <div class="stat-content">
                    <h4>Produtos</h4>
                    <div class="value">{{campaign.shirts.length}}</div>
                </div>
            </div>
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper green">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <div class="stat-content">
                    <h4>Pedidos</h4>
                    <div class="value">0</div> <!-- Placeholder -->
                </div>
            </div>
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper purple">
                    <i class="fas fa-dollar-sign"></i>
                </div>
                <div class="stat-content">
                    <h4>Arrecadado</h4>
                    <div class="value">R$ 0,00</div> <!-- Placeholder -->
                </div>
            </div>
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper orange">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-content">
                    <h4>Dias Restantes</h4>
                    <div class="value">{{campaign.daysRemaining}}</div>
                </div>
            </div>
        </div>

        <div class="details-grid-layout">
            <!-- Left Column: General Info & Products -->
            <div class="left-col">
                <!-- General Info Card -->
                <div class="details-card">
                    <div class="card-header">
                        <h3><i class="fas fa-info-circle"></i> Informações Gerais</h3>
                        <span class="badge badge-{{campaign.status}}">
                            {{#if (eq campaign.status 'active')}}Ativa{{/if}}
                            {{#if (eq campaign.status 'inactive')}}Inativa{{/if}}
                            {{#if (eq campaign.status 'draft')}}Rascunho{{/if}}
                        </span>
                    </div>
                    <div class="card-body">
                        <div class="details-data-grid">
                            <!-- Description -->
                            <div class="data-item full-width">
                                <div class="data-icon purple">
                                    <i class="fas fa-align-left"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Descrição</span>
                                    <span class="data-value">{{campaign.description}}</span>
                                </div>
                            </div>

                            <!-- Date -->
                            <div class="data-item">
                                <div class="data-icon blue">
                                    <i class="far fa-calendar-alt"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Período</span>
                                    <span class="data-value">{{formatDate campaign.startDate}} - {{formatDate campaign.endDate}}</span>
                                </div>
                            </div>

                            <!-- Created At -->
                            <div class="data-item">
                                <div class="data-icon orange">
                                    <i class="far fa-clock"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Criada em</span>
                                    <span class="data-value">{{formatDate campaign.createdAt}}</span>
                                </div>
                            </div>

                            <!-- Access Code -->
                            <div class="data-item full-width">
                                <div class="data-icon green">
                                    <i class="fas fa-key"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Código de Acesso</span>
                                    <div class="data-value" style="display: flex; align-items: center; gap: 10px;">
                                        <code style="background: #f1f5f9; padding: 4px 10px; border-radius: 8px; border: 1px solid #e2e8f0; font-family: monospace; color: #475569; font-weight: 700; font-size: 1.1rem;">{{campaign.accessCode}}</code>
                                        <button class="copy-btn" onclick="copyToClipboard('{{campaign.accessCode}}')" title="Copiar Código">
                                            <i class="far fa-copy"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Products Card -->
                <div class="details-card">
                    <div class="card-header">
                        <h3><i class="fas fa-tshirt"></i> Produtos Disponíveis</h3>
                    </div>
                    <div class="card-body">
                        <div class="products-grid-mini">
                            {{#each campaign.shirts}}
                            <div class="mini-product-card">
                                <div class="mini-product-image-wrapper">
                                    {{#if this.images.[0]}}
                                        <img src="{{this.images.[0]}}" alt="{{this.name}}" class="mini-product-image">
                                    {{else}}
                                        <div class="mini-product-placeholder">
                                            <i class="fas fa-tshirt"></i>
                                        </div>
                                    {{/if}}
                                    <div class="product-price-badge">
                                        R$ {{this.price}}
                                    </div>
                                </div>
                                
                                <div class="mini-product-details">
                                    <h4 class="mini-product-title" title="{{this.name}}">{{this.name}}</h4>
                                    
                                    <div class="mini-product-specs">
                                        <div class="spec-item">
                                            <i class="fas fa-tag"></i> <span>{{this.type}}</span>
                                        </div>
                                        <div class="spec-item">
                                            <i class="fas fa-palette"></i> <span>{{this.color}}</span>
                                        </div>
                                    </div>

                                    <div class="mini-product-sizes">
                                        {{#each (split this.sizes ',')}}
                                        <span class="size-pill">{{this}}</span>
                                        {{/each}}
                                    </div>
                                </div>
                            </div>
                            {{/each}}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Client & Actions -->
            <div class="right-col">
                <!-- Client Info Card -->
                <div class="details-card">
                    <div class="card-header">
                        <h3><i class="fas fa-user-tie"></i> Dados do Cliente</h3>
                    </div>
                    <div class="card-body">
                        <div class="details-data-grid" style="grid-template-columns: 1fr;">
                            <div class="data-item">
                                <div class="data-icon blue">
                                    <i class="fas fa-user"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Nome</span>
                                    <span class="data-value">{{campaign.clientName}}</span>
                                </div>
                            </div>
                            
                            <div class="data-item">
                                <div class="data-icon green">
                                    <i class="fas fa-phone"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Telefone</span>
                                    <span class="data-value">{{campaign.clientPhone}}</span>
                                </div>
                            </div>

                            <div class="data-item">
                                <div class="data-icon pink">
                                    <i class="fab fa-instagram"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Instagram</span>
                                    <span class="data-value">
                                        {{#if campaign.clientInstagram}}
                                        <a href="https://instagram.com/{{campaign.clientInstagram}}" target="_blank" style="color: #d62976; text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 5px;">
                                            @{{campaign.clientInstagram}} <i class="fas fa-external-link-alt" style="font-size: 0.7rem;"></i>
                                        </a>
                                        {{else}}
                                        <span style="color: #94a3b8;">Não informado</span>
                                        {{/if}}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions / Export -->
                <div class="details-card">
                    <div class="card-header">
                        <h3><i class="fas fa-bolt"></i> Ações Rápidas</h3>
                    </div>
                    <div class="card-body">
                        <div class="quick-actions-grid">
                            <button class="action-tile-btn excel">
                                <i class="fas fa-file-excel"></i>
                                <span>Exportar Pedidos</span>
                            </button>
                            <button class="action-tile-btn share">
                                <i class="fas fa-share-alt"></i>
                                <span>Compartilhar Link</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
        // Could add a toast notification here
        alert('Código copiado!');
    });
}
</script>

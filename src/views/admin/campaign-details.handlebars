<div class="admin-layout">
    {{> admin-sidebar}}

    <main class="admin-main-content">
        <!-- Compact Header -->
        <div class="dashboard-header-compact">
            <div class="header-title">
                <h2>{{campaign.title}}</h2>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/admin/campanhas">Campanhas</a></li>
                    <li class="breadcrumb-item active">Detalhes</li>
                </ul>
            </div>
            <div class="header-actions">
                <a href="/admin/campanhas/editar/{{campaign.id}}" class="btn btn-primary">
                    <i class="fas fa-edit"></i> Editar Campanha
                </a>
            </div>
        </div>

        {{#if success}}
        <div class="alert alert-success">{{success}}</div>
        {{/if}}

        <!-- Campaign Stats Row -->
        <div class="details-stats-grid">
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper blue">
                    <i class="fas fa-tshirt"></i>
                </div>
                <div class="stat-content">
                    <h4>Produtos</h4>
                    <div class="value">{{campaign.shirts.length}}</div>
                </div>
            </div>
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper green">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <div class="stat-content">
                    <h4>Pedidos</h4>
                    <div class="value">0</div> <!-- Placeholder -->
                </div>
            </div>
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper purple">
                    <i class="fas fa-dollar-sign"></i>
                </div>
                <div class="stat-content">
                    <h4>Arrecadado</h4>
                    <div class="value">R$ 0,00</div> <!-- Placeholder -->
                </div>
            </div>
            <div class="detail-stat-card">
                <div class="stat-icon-wrapper orange">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-content">
                    <h4>Dias Restantes</h4>
                    <div class="value">{{campaign.daysRemaining}}</div>
                </div>
            </div>
        </div>

        <div class="details-grid-layout">
            <!-- Left Column: General Info & Products -->
            <div class="left-col">
                <!-- General Info Card -->
                <div class="details-card">
                    <div class="card-header">
                        <h3><i class="fas fa-info-circle"></i> Informações Gerais</h3>
                        <span class="badge badge-{{campaign.status}}">
                            {{#if (eq campaign.status 'active')}}Ativa{{/if}}
                            {{#if (eq campaign.status 'inactive')}}Inativa{{/if}}
                        </span>
                    </div>
                    <div class="card-body">
                        <div class="details-data-grid">
                            <!-- Description -->
                            <div class="data-item full-width">
                                <div class="data-icon purple">
                                    <i class="fas fa-align-left"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Descrição</span>
                                    <span class="data-value">{{campaign.description}}</span>
                                </div>
                            </div>

                            <!-- Date -->
                            <div class="data-item">
                                <div class="data-icon blue">
                                    <i class="far fa-calendar-alt"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Período</span>
                                    <span class="data-value">{{formatDate campaign.startDate}} - {{formatDate campaign.endDate}}</span>
                                </div>
                            </div>

                            <!-- Created At -->
                            <div class="data-item">
                                <div class="data-icon orange">
                                    <i class="far fa-clock"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Criada em</span>
                                    <span class="data-value">{{formatDate campaign.createdAt}}</span>
                                </div>
                            </div>

                            <!-- Access Code -->
                            <div class="data-item full-width">
                                <div class="data-icon green">
                                    <i class="fas fa-key"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Código de Acesso</span>
                                    <div class="data-value" style="display: flex; align-items: center; gap: 10px;">
                                        <code style="background: #f1f5f9; padding: 4px 10px; border-radius: 8px; border: 1px solid #e2e8f0; font-family: monospace; color: #475569; font-weight: 700; font-size: 1.1rem;">{{campaign.accessCode}}</code>
                                        <button class="copy-btn" onclick="copyToClipboard('{{campaign.accessCode}}')" title="Copiar Código">
                                            <i class="far fa-copy"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="details-card">
                    <div class="card-header">
                        <h3><i class="fas fa-tshirt"></i> Produtos Disponíveis</h3>
                        <button 
                            type="button" 
                            class="btn-mini btn-add-product" 
                            id="addProductBtn"
                            data-campaign-id="{{campaign.id}}"
                        >
                            <i class="fas fa-plus"></i>
                            <span>Novo produto</span>
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="products-grid-mini">
                            {{#each campaign.shirts}}
                            <div class="mini-product-card">
                                <div class="mini-product-image-wrapper" data-images='{{json this.images}}' data-index="0">
                                    {{#if this.images.[0]}}
                                        <img src="{{this.images.[0]}}" alt="{{this.name}}" class="mini-product-image">
                                        {{#if this.images.[1]}}
                                        <div class="mini-product-multi">
                                            <span class="multi-count">{{this.images.length}} fotos</span>
                                        </div>
                                        <button type="button" class="mini-image-nav prev"><i class="fas fa-chevron-left"></i></button>
                                        <button type="button" class="mini-image-nav next"><i class="fas fa-chevron-right"></i></button>
                                        {{/if}}
                                    {{else}}
                                        <div class="mini-product-placeholder">
                                            <i class="fas fa-tshirt"></i>
                                        </div>
                                    {{/if}}
                                    <div class="product-price-badge">
                                        R$ {{this.price}}
                                    </div>
                                </div>
                                
                                <div class="mini-product-details">
                                    <h4 class="mini-product-title" title="{{this.name}}">{{this.name}}</h4>
                                    
                                    <div class="mini-product-specs">
                                        <div class="spec-item">
                                            <i class="fas fa-tag"></i> <span>{{this.type}}</span>
                                        </div>
                                        <div class="spec-item">
                                            <i class="fas fa-palette"></i> <span>{{this.color}}</span>
                                        </div>
                                    </div>

                                    <div class="mini-product-sizes">
                                        {{#each (split this.sizes ',')}}
                                        <span class="size-pill">{{this}}</span>
                                        {{/each}}
                                    </div>
                                </div>

                                <div class="mini-product-actions">
                                    <button 
                                        type="button" 
                                        class="btn-mini btn-edit-product"
                                        data-edit-shirt-id="{{this.id}}"
                                        data-edit-campaign-id="{{../id}}"
                                        data-edit-name="{{this.name}}"
                                        data-edit-color="{{this.color}}"
                                        data-edit-type="{{this.type}}"
                                        data-edit-price="{{this.price}}"
                                        data-edit-sizes="{{this.sizes}}"
                                    >
                                        <i class="fas fa-pen-to-square"></i>
                                        <span>Editar</span>
                                    </button>
                                    <form action="/admin/campanhas/{{../id}}/camisas/deletar/{{this.id}}" method="POST" class="inline-delete" onsubmit="return confirm('Deseja realmente apagar este modelo?');">
                                        <button type="submit" class="btn-mini delete">
                                            <i class="fas fa-trash"></i>
                                            <span>Apagar</span>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            {{/each}}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Campaign Leader & Actions -->
            <div class="right-col">
                <!-- Campaign Leader Info Card -->
                <div class="details-card">
                    <div class="card-header">
                        <h3><i class="fas fa-user-tie"></i> Dados do Líder da Campanha</h3>
                    </div>
                    <div class="card-body">
                        <div class="details-data-grid" style="grid-template-columns: 1fr;">
                            <div class="data-item">
                                <div class="data-icon blue">
                                    <i class="fas fa-user"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Nome</span>
                                    <span class="data-value">{{campaign.clientName}}</span>
                                </div>
                            </div>
                            
                            <div class="data-item">
                                <div class="data-icon green">
                                    <i class="fas fa-phone"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Telefone</span>
                                    <span class="data-value">{{campaign.clientPhone}}</span>
                                </div>
                            </div>

                            <div class="data-item">
                                <div class="data-icon pink">
                                    <i class="fab fa-instagram"></i>
                                </div>
                                <div class="data-content">
                                    <span class="data-label">Instagram</span>
                                    <span class="data-value">
                                        {{#if campaign.clientInstagram}}
                                        <a href="https://instagram.com/{{campaign.clientInstagram}}" target="_blank" style="color: #d62976; text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 5px;">
                                            @{{campaign.clientInstagram}} <i class="fas fa-external-link-alt" style="font-size: 0.7rem;"></i>
                                        </a>
                                        {{else}}
                                        <span style="color: #94a3b8;">Não informado</span>
                                        {{/if}}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions / Export -->
                <div class="details-card">
                    <div class="card-header">
                        <h3><i class="fas fa-bolt"></i> Ações Rápidas</h3>
                    </div>
                    <div class="card-body">
                        <div class="quick-actions-grid">
                            <button class="action-tile-btn excel">
                                <i class="fas fa-file-excel"></i>
                                <span>Exportar Pedidos</span>
                            </button>
                            <button class="action-tile-btn share" data-share-url="/c/{{campaign.accessCode}}">
                                <i class="fas fa-share-alt"></i>
                                <span>Compartilhar Link</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<div class="mini-edit-modal-backdrop" id="miniEditModal">
    <div class="mini-edit-modal">
        <div class="mini-edit-header">
            <h3>Editar produto</h3>
            <button type="button" class="mini-edit-close" data-close-mini-edit>&times;</button>
        </div>
        <form id="miniEditForm" method="POST">
            <div class="mini-edit-body">
                <div class="mini-edit-group">
                    <label>Nome do modelo</label>
                    <input type="text" name="name" class="form-control" required>
                </div>
                <div class="mini-edit-row">
                    <div class="mini-edit-group">
                        <label>Cor</label>
                        <input type="text" name="color" class="form-control">
                    </div>
                    <div class="mini-edit-group">
                        <label>Corte</label>
                        <select name="type" class="form-control">
                            <option value="Tradicional">Tradicional</option>
                            <option value="Oversized">Oversized</option>
                            <option value="Cropped">Cropped</option>
                            <option value="Infant">Infant</option>
                        </select>
                    </div>
                </div>
                <div class="mini-edit-row">
                    <div class="mini-edit-group">
                        <label>Preço (R$)</label>
                        <input type="number" step="0.01" name="price" class="form-control" required>
                    </div>
                    <div class="mini-edit-group">
                        <label>Tamanhos Disponíveis</label>
                        <div class="sizes-wrapper mini-edit-sizes-wrapper">
                            <input type="hidden" name="sizes" class="shirt-sizes-input" value="">
                            <div class="size-options"></div>
                        </div>
                    </div>
                </div>
                <div class="mini-edit-group mini-edit-images">
                    <label>Imagens do modelo</label>
                    <div class="mini-edit-images-wrapper">
                        <input type="hidden" name="imagesJSON" class="mini-edit-images-json" value="[]">
                        <input type="file" accept="image/*" class="mini-edit-image-file" style="display:none">
                        <button type="button" class="btn-mini btn-upload-image mini-edit-upload" data-mini-upload>
                            <i class="fas fa-cloud-upload-alt"></i>
                            <span>Adicionar imagem</span>
                        </button>
                        <div class="mini-edit-images-grid"></div>
                    </div>
                </div>
            </div>
            <div class="mini-edit-footer">
                <button type="button" class="btn btn-outline" data-close-mini-edit>Cancelar</button>
                <button type="submit" class="btn btn-primary">Salvar alterações</button>
            </div>
        </form>
    </div>
</div>

<script>
const MINI_SIZE_PRESETS = {
    Tradicional: ['P', 'M', 'G', 'GG', 'XG', 'ExGG', 'P baby look', 'M baby look', 'G baby look'],
    Infant: ['2', '4', '6', '8', '10', '12', '14'],
    Default: ['P', 'M', 'G', 'GG', 'XG']
};

function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
        alert('Código copiado!');
    });
}

document.addEventListener('DOMContentLoaded', function() {
    const shareBtn = document.querySelector('.action-tile-btn.share');
    if (shareBtn) {
        shareBtn.addEventListener('click', function() {
            const path = shareBtn.getAttribute('data-share-url') || '';
            const url = window.location.origin + path;
            copyToClipboard(url);
            alert('Link da campanha copiado!');
        });
    }

    initMiniEdit();
    initMiniGalleries();
});

function initMiniEdit() {
    const modal = document.getElementById('miniEditModal');
    const form = document.getElementById('miniEditForm');
    if (!modal || !form) return;

    document.querySelectorAll('[data-close-mini-edit]').forEach(el => {
        el.addEventListener('click', () => {
            modal.classList.remove('visible');
        });
    });

    modal.addEventListener('click', function(e) {
        if (e.target === modal) {
            modal.classList.remove('visible');
        }
    });

    const addBtn = document.getElementById('addProductBtn');
    if (addBtn) {
        addBtn.addEventListener('click', function() {
            const campaignId = addBtn.dataset.campaignId;
            form.action = `/admin/campanhas/${campaignId}/camisas/criar`;
            form.name.value = '';
            form.color.value = '';
            form.type.value = 'Tradicional';
            form.price.value = '';

            const sizesWrapper = form.querySelector('.mini-edit-sizes-wrapper');
            const sizesInput = sizesWrapper ? sizesWrapper.querySelector('.shirt-sizes-input') : null;
            if (sizesInput) {
                sizesInput.value = '';
                applyMiniSizePreset(form, '');
            }

            setupMiniImages(form, []);
            modal.classList.add('visible');
        });
    }

    const typeSelect = form.querySelector('select[name="type"]');
    if (typeSelect) {
        typeSelect.addEventListener('change', function() {
            const sizesWrapper = form.querySelector('.mini-edit-sizes-wrapper');
            const sizesInput = sizesWrapper ? sizesWrapper.querySelector('.shirt-sizes-input') : null;
            if (sizesInput) {
                applyMiniSizePreset(form, sizesInput.value);
            }
        });
    }

    const uploadBtn = form.querySelector('[data-mini-upload]');
    const fileInput = form.querySelector('.mini-edit-image-file');
    if (uploadBtn && fileInput) {
        uploadBtn.addEventListener('click', function() {
            fileInput.click();
        });
        fileInput.addEventListener('change', function() {
            handleMiniImageSelected(form, fileInput);
        });
    }

    const imagesGrid = form.querySelector('.mini-edit-images-grid');
    if (imagesGrid) {
        imagesGrid.addEventListener('click', function(e) {
            const btn = e.target.closest('[data-remove-mini-image]');
            if (!btn) return;
            const index = parseInt(btn.dataset.index, 10);
            removeMiniImage(form, index);
        });
    }

    document.querySelectorAll('.btn-edit-product').forEach(btn => {
        btn.addEventListener('click', function() {
            openMiniEdit(this);
        });
    });
}

function initMiniGalleries() {
    const wrappers = document.querySelectorAll('.mini-product-image-wrapper[data-images]');
    wrappers.forEach(wrapper => {
        const raw = wrapper.getAttribute('data-images') || '[]';
        let images = [];
        try {
            images = JSON.parse(raw);
        } catch (e) {
            images = [];
        }
        if (!images || images.length <= 1) return;

        const imgEl = wrapper.querySelector('.mini-product-image');
        if (!imgEl) return;

        let index = 0;
        const prevBtn = wrapper.querySelector('.mini-image-nav.prev');
        const nextBtn = wrapper.querySelector('.mini-image-nav.next');

        const updateImage = () => {
            imgEl.src = images[index];
        };

        if (prevBtn) {
            prevBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                index = (index - 1 + images.length) % images.length;
                updateImage();
            });
        }

        if (nextBtn) {
            nextBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                index = (index + 1) % images.length;
                updateImage();
            });
        }
    });
}

function applyMiniSizePreset(form, currentValue) {
    const wrapper = form.querySelector('.mini-edit-sizes-wrapper');
    if (!wrapper) return;
    const select = form.querySelector('select[name="type"]');
    const type = select ? select.value || '' : '';
    let preset = MINI_SIZE_PRESETS.Default;
    if (type === 'Tradicional') {
        preset = MINI_SIZE_PRESETS.Tradicional;
    } else if (type === 'Infant') {
        preset = MINI_SIZE_PRESETS.Infant;
    }
    const sizeOptions = wrapper.querySelector('.size-options');
    const sizesInput = wrapper.querySelector('.shirt-sizes-input');
    if (!sizeOptions || !sizesInput) return;
    sizeOptions.innerHTML = '';
    const currentSizes = currentValue ? currentValue.split(',').map(s => s.trim()).filter(Boolean) : [];
    preset.forEach(size => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'size-chip mini-edit-size-chip';
        btn.dataset.value = size;
        btn.textContent = size;
        if (!currentSizes.length || currentSizes.includes(size)) {
            btn.classList.add('active');
        }
        sizeOptions.appendChild(btn);
    });
    updateMiniSizesInput(wrapper);

    sizeOptions.addEventListener('click', function(e) {
        const chip = e.target.closest('.mini-edit-size-chip');
        if (!chip) return;
        chip.classList.toggle('active');
        updateMiniSizesInput(wrapper);
    });
}

function updateMiniSizesInput(wrapper) {
    const chips = wrapper.querySelectorAll('.mini-edit-size-chip.active');
    const values = Array.from(chips).map(c => c.dataset.value);
    const input = wrapper.querySelector('.shirt-sizes-input');
    if (input) {
        input.value = values.join(', ');
    }
}

function setupMiniImages(form, images) {
    const jsonInput = form.querySelector('.mini-edit-images-json');
    const grid = form.querySelector('.mini-edit-images-grid');
    if (!jsonInput || !grid) return;
    jsonInput.value = JSON.stringify(images || []);
    grid.innerHTML = '';
    (images || []).forEach((src, index) => {
        const item = document.createElement('div');
        item.className = 'mini-edit-image-item';
        item.innerHTML = `
            <img src="${src}" class="mini-edit-image-thumb">
            <button type="button" class="mini-edit-image-remove" data-remove-mini-image data-index="${index}">&times;</button>
        `;
        grid.appendChild(item);
    });
}

function handleMiniImageSelected(form, input) {
    if (!input.files || !input.files.length) return;
    const file = input.files[0];
    if (file.size > 5 * 1024 * 1024) {
        alert('A imagem deve ter no máximo 5MB.');
        input.value = '';
        return;
    }
    const reader = new FileReader();
    reader.onload = function(e) {
        const base64 = e.target.result;
        addMiniImage(form, base64);
        input.value = '';
    };
    reader.readAsDataURL(file);
}

function addMiniImage(form, base64) {
    const jsonInput = form.querySelector('.mini-edit-images-json');
    const grid = form.querySelector('.mini-edit-images-grid');
    if (!jsonInput || !grid) return;
    let images = [];
    try {
        images = JSON.parse(jsonInput.value || '[]');
    } catch (e) {
        images = [];
    }
    images.push(base64);
    setupMiniImages(form, images);
}

function removeMiniImage(form, index) {
    const jsonInput = form.querySelector('.mini-edit-images-json');
    if (!jsonInput) return;
    let images = [];
    try {
        images = JSON.parse(jsonInput.value || '[]');
    } catch (e) {
        images = [];
    }
    if (index < 0 || index >= images.length) return;
    images.splice(index, 1);
    setupMiniImages(form, images);
}

function openMiniEdit(btn) {
    const modal = document.getElementById('miniEditModal');
    const form = document.getElementById('miniEditForm');
    if (!modal || !form || !btn) return;

    try {
        const shirtId = btn.getAttribute('data-edit-shirt-id');
        const campaignId = btn.getAttribute('data-edit-campaign-id');
        if (!shirtId || !campaignId) return;

        const name = btn.getAttribute('data-edit-name') || '';
        const color = btn.getAttribute('data-edit-color') || '';
        const type = btn.getAttribute('data-edit-type') || 'Tradicional';
        const price = btn.getAttribute('data-edit-price') || '';
        const sizes = btn.getAttribute('data-edit-sizes') || '';

        form.action = `/admin/campanhas/${campaignId}/camisas/editar/${shirtId}`;
        form.name.value = name;
        form.color.value = color;
        form.type.value = type;
        form.price.value = price;

        const sizesWrapper = form.querySelector('.mini-edit-sizes-wrapper');
        const sizesInput = sizesWrapper ? sizesWrapper.querySelector('.shirt-sizes-input') : null;
        if (sizesInput) {
            sizesInput.value = sizes;
            applyMiniSizePreset(form, sizes);
        }

        const card = btn.closest('.mini-product-card');
        let images = [];
        if (card) {
            const imgWrapper = card.querySelector('.mini-product-image-wrapper[data-images]');
            if (imgWrapper) {
                const raw = imgWrapper.getAttribute('data-images') || '[]';
                try {
                    images = JSON.parse(raw);
                } catch (e) {
                    images = [];
                }
            }
        }
        setupMiniImages(form, images);
    } catch (e) {
        console.error(e);
    }

    modal.classList.add('visible');
}
</script>

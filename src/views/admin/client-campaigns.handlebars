<div class="admin-layout">
    {{> admin-sidebar}}

    <main class="admin-main-content">
        <div class="dashboard-header-compact">
            <div class="header-title">
                <h2>Clientes e Campanhas</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Clientes e Campanhas</li>
                    </ol>
                </nav>
            </div>
        </div>

        {{#if success}}
        <div class="alert alert-success">{{success}}</div>
        {{/if}}

        {{#if error}}
        <div class="alert alert-danger">{{error}}</div>
        {{/if}}

        {{#if editUser}}
        <div class="campaigns-container" style="margin-bottom: 1.5rem;">
            <div class="campaigns-list">
                <div class="details-card">
                    <div class="card-header">
                        <h3><i class="fas fa-user-edit"></i> Editar Cliente</h3>
                    </div>
                    <div class="card-body">
                        <form action="/admin/clientes-campanhas/editar/{{editUser.id}}" method="POST" class="admin-form">
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="name">Nome</label>
                                    <input type="text" id="name" name="name" class="form-control" value="{{editUser.name}}" required>
                                </div>
                                <div class="form-group">
                                    <label for="email">E-mail</label>
                                    <input type="email" id="email" name="email" class="form-control" value="{{editUser.email}}" required>
                                </div>
                                <div class="form-group">
                                    <label for="phone">Telefone</label>
                                    <input type="text" id="phone" name="phone" class="form-control" value="{{editUser.phone}}">
                                </div>
                            </div>
                            <div class="form-actions" style="margin-top: 1rem;">
                                <button type="submit" class="btn btn-primary">Salvar alterações</button>
                                <a href="/admin/clientes-campanhas" class="btn btn-secondary">Cancelar</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {{/if}}

        <div class="campaigns-container">
            <div class="search-bar-wrapper">
                <div class="search-input-group">
                    <i class="fas fa-search"></i>
                    <input 
                        type="text" 
                        id="clientCampaignSearch" 
                        class="search-input" 
                        placeholder="Buscar por cliente ou campanha..." 
                        onkeyup="filterClientCampaigns()">
                </div>
            </div>
            <div class="campaigns-list">
                {{#if users.length}}
                <div class="table-responsive">
                    <table class="admin-table" id="clientsTable">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Contato</th>
                                <th>Campanhas</th>
                                <th>Pedidos</th>
                                <th>Total Gasto</th>
                                <th>Última compra</th>
                                <th style="text-align: right;">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each users}}
                            <tr>
                                <td>
                                    <div class="client-cell">
                                        <strong>{{this.name}}</strong>
                                        <small>{{this.email}}</small>
                                    </div>
                                </td>
                                <td>
                                    {{#if this.phone}}
                                    <span>{{this.phone}}</span>
                                    {{else}}
                                    <span class="text-muted">Sem telefone</span>
                                    {{/if}}
                                </td>
                                <td>
                                    {{#if this.campaigns.length}}
                                    <div class="client-campaigns-list">
                                        {{#each this.campaigns}}
                                        <div class="client-campaign-pill">
                                            <div class="client-campaign-pill-title">{{this.title}}</div>
                                            <div class="client-campaign-pill-meta">
                                                Código: {{this.accessCode}} · Pedidos: {{this.totalOrders}} · Itens: {{this.totalItems}}
                                            </div>
                                        </div>
                                        {{/each}}
                                    </div>
                                    {{else}}
                                    <span class="text-muted">Nenhuma campanha</span>
                                    {{/if}}
                                </td>
                                <td>
                                    <span class="stat-value">{{this.totalOrders}}</span>
                                </td>
                                <td>
                                    <div class="stat-value">R$ {{this.totalSpentFormatted}}</div>
                                    <div class="client-total-net">Líquido: R$ {{this.totalNetSpentFormatted}}</div>
                                    {{#if this.paymentMethods.length}}
                                    <div class="client-methods-row">
                                        {{#each this.paymentMethods}}
                                        <span class="client-method-pill">{{this}}</span>
                                        {{/each}}
                                    </div>
                                    {{/if}}
                                </td>
                                <td>
                                    {{#if this.lastOrderDate}}
                                    <small class="client-last-order-date">{{formatDate this.lastOrderDate}}</small>
                                    {{else}}
                                    <span class="text-muted">Sem compras</span>
                                    {{/if}}
                                </td>
                                <td style="text-align: right;">
                                    <div class="action-buttons">
                                        <a href="/admin/clientes-campanhas?orders={{this.id}}" class="btn-icon details" title="Ver pedidos">
                                            <i class="fas fa-shopping-bag"></i>
                                        </a>
                                        <a href="/admin/clientes-campanhas?edit={{this.id}}" class="btn-icon edit" title="Editar cliente">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form action="/admin/clientes-campanhas/deletar/{{this.id}}" method="POST" style="display: inline;" onsubmit="return confirm('Tem certeza que deseja excluir este cliente?');">
                                            <button type="submit" class="btn-icon delete" title="Excluir cliente">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
                {{else}}
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-user-friends"></i></div>
                    <h3>Nenhum cliente encontrado</h3>
                    <p>Os clientes serão exibidos aqui conforme realizarem pedidos na loja.</p>
                </div>
                {{/if}}
            </div>
        </div>

        {{#if selectedUser}}
        <div class="client-orders-modal">
            <div class="client-orders-modal-backdrop" onclick="window.location='/admin/clientes-campanhas';"></div>
            <div class="client-orders-modal-content">
                <div class="client-orders-modal-header">
                    <div>
                        <h3>
                            <i class="fas fa-shopping-bag"></i>
                            Pedidos de {{selectedUser.name}}
                        </h3>
                        <span class="client-orders-subtitle">{{selectedUser.email}}</span>
                    </div>
                    <button type="button" class="client-orders-modal-close" onclick="window.location='/admin/clientes-campanhas';">&times;</button>
                </div>
                <div class="client-orders-modal-body">
                    {{#if selectedUserOrders.length}}
                    <div class="client-orders-summary">
                        <div class="client-orders-summary-item">
                            <span class="client-orders-summary-label">Pedidos aprovados</span>
                            <span class="client-orders-summary-value">{{selectedUser.totalOrders}}</span>
                        </div>
                        <div class="client-orders-summary-item">
                            <span class="client-orders-summary-label">Total bruto</span>
                            <span class="client-orders-summary-value">R$ {{selectedUser.totalSpentFormatted}}</span>
                        </div>
                        <div class="client-orders-summary-item">
                            <span class="client-orders-summary-label">Total líquido</span>
                            <span class="client-orders-summary-value">R$ {{selectedUser.totalNetSpentFormatted}}</span>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="admin-table client-orders-table">
                            <thead>
                                <tr>
                                    <th>Pedido</th>
                                    <th>Campanha</th>
                                    <th>Valor</th>
                                    <th>Líquido</th>
                                    <th>Método</th>
                                    <th>Status</th>
                                    <th>Itens</th>
                                    <th>Data</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each selectedUserOrders}}
                                <tr>
                                    <td>#{{this.id}}</td>
                                    <td>
                                        {{#if this.campaignTitle}}
                                            <strong>{{this.campaignTitle}}</strong>
                                            {{#if this.campaignAccessCode}}
                                            <div class="client-order-campaign-code">Código: {{this.campaignAccessCode}}</div>
                                            {{/if}}
                                        {{else}}
                                            <span class="badge badge-secondary">Sem campanha</span>
                                        {{/if}}
                                    </td>
                                    <td>R$ {{this.finalAmountFormatted}}</td>
                                    <td>R$ {{this.netAmountFormatted}}</td>
                                    <td>{{#if this.paymentMethodLabel}}{{this.paymentMethodLabel}}{{else}}<span class="text-muted">N/I</span>{{/if}}</td>
                                    <td>
                                        <span class="client-order-status client-order-status-{{this.status}}">
                                            {{this.status}}
                                        </span>
                                    </td>
                                    <td>
                                        <span class="client-order-items-count">{{this.itemsQty}} iten{{#unless (eq this.itemsQty 1)}}s{{/unless}}</span>
                                        {{#if this.items.length}}
                                        <button type="button" class="btn btn-link client-order-items-btn" onclick="openOrderItemsModal('{{this.id}}')">
                                            Ver itens
                                        </button>
                                        {{/if}}
                                    </td>
                                    <td>{{#if this.createdAt}}{{formatDate this.createdAt}}{{/if}}</td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                    {{else}}
                    <p class="text-muted">Este cliente ainda não possui pedidos.</p>
                    {{/if}}
                </div>
            </div>
        </div>
        {{/if}}

        {{#if selectedUserOrders.length}}
        {{#each selectedUserOrders}}
        <div id="order-items-modal-{{this.id}}" class="order-items-modal" style="display: none;">
            <div class="order-items-modal-backdrop" onclick="closeOrderItemsModal('{{this.id}}')"></div>
            <div class="order-items-modal-content">
                <div class="order-items-modal-header">
                    <h4>Itens do pedido #{{this.id}}</h4>
                    <button type="button" class="order-items-modal-close" onclick="closeOrderItemsModal('{{this.id}}')">&times;</button>
                </div>
                <div class="order-items-modal-body">
                    {{#if this.items.length}}
                    <ul>
                        {{#each this.items}}
                        <li class="order-item-row">
                            {{#if this.thumb}}
                            <div class="order-item-image">
                                <img src="{{this.thumb}}" alt="{{this.displayName}}">
                            </div>
                            {{/if}}
                            <div class="order-item-details">
                                <div class="order-item-name">
                                    {{this.qty}}x {{this.name}}
                                </div>
                                <div class="order-item-meta">
                                    {{#if this.color}}<small class="text-muted d-block">Cor: {{this.color}}</small>{{/if}}
                                    {{#if this.size}}<small class="text-muted d-block">Tamanho: {{this.size}}</small>{{/if}}
                                    <small class="text-muted d-block">R$ {{this.price}}</small>
                                </div>
                            </div>
                        </li>
                        {{/each}}
                    </ul>
                    {{else}}
                    <p class="text-muted">Nenhum item encontrado para este pedido.</p>
                    {{/if}}
                </div>
            </div>
        </div>
        {{/each}}
        {{/if}}
    </main>
</div>

<style>
.order-items-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1000;
}
.order-items-modal-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(15, 23, 42, 0.55);
}
.order-items-modal-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #ffffff;
    border-radius: 8px;
    max-width: 480px;
    width: 90%;
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.15);
}
.order-items-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid #e2e8f0;
}
.order-items-modal-header h4 {
    margin: 0;
    font-size: 1rem;
}
.order-items-modal-close {
    background: none;
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    color: #64748b;
}
.order-items-modal-body {
    padding: 12px 16px;
    max-height: 320px;
    overflow-y: auto;
}
.order-items-modal-body ul {
    margin: 0;
    padding-left: 18px;
}
.order-items-modal-body li {
    font-size: 0.9rem;
    margin-bottom: 4px;
}
.order-item-row {
    display: flex;
    align-items: center;
    gap: 8px;
}
.order-item-image img {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    object-fit: cover;
    border: 1px solid #e2e8f0;
}
.order-item-text {
    display: flex;
    flex-direction: column;
}
.order-item-title {
    font-weight: 500;
}
.order-item-meta {
    font-size: 0.8rem;
    color: #64748b;
}
.client-campaigns-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}
.client-campaign-pill {
    padding: 6px 10px;
    border-radius: 999px;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
}
.client-campaign-pill-title {
    font-size: 0.85rem;
    font-weight: 600;
}
.client-campaign-pill-meta {
    font-size: 0.75rem;
    color: #64748b;
}
.client-total-net {
    font-size: 0.85rem;
    color: #64748b;
}
.client-methods-row {
    margin-top: 4px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
}
.client-method-pill {
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: 999px;
    background: #eff6ff;
    color: #1d4ed8;
    border: 1px solid #bfdbfe;
}
.client-last-order-date {
    font-size: 0.8rem;
    color: #64748b;
}
.client-orders-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 950;
}
.client-orders-modal-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(15, 23, 42, 0.55);
}
.client-orders-modal-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #ffffff;
    border-radius: 10px;
    max-width: 960px;
    width: 95%;
    max-height: 80vh;
    box-shadow: 0 15px 35px rgba(15, 23, 42, 0.25);
    display: flex;
    flex-direction: column;
}
.client-orders-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid #e2e8f0;
}
.client-orders-modal-header h3 {
    margin: 0;
    font-size: 1.05rem;
}
.client-orders-subtitle {
    display: block;
    font-size: 0.85rem;
    color: #64748b;
}
.client-orders-modal-close {
    background: none;
    border: none;
    font-size: 1.4rem;
    cursor: pointer;
    color: #64748b;
}
.client-orders-modal-body {
    padding: 12px 16px;
    overflow: auto;
}
.client-orders-summary {
    display: flex;
    gap: 12px;
    margin-bottom: 8px;
}
.client-orders-summary-item {
    flex: 1;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    padding: 8px 10px;
}
.client-orders-summary-label {
    display: block;
    font-size: 0.75rem;
    color: #64748b;
}
.client-orders-summary-value {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    margin-top: 2px;
}
.client-orders-table td {
    vertical-align: middle;
}
.client-order-campaign-code {
    font-size: 0.8rem;
    color: #64748b;
}
.client-order-status {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.75rem;
    text-transform: capitalize;
}
.client-order-status-approved {
    background: #dcfce7;
    color: #166534;
}
.client-order-status-pending {
    background: #fef9c3;
    color: #92400e;
}
.client-order-status-cancelled,
.client-order-status-rejected {
    background: #fee2e2;
    color: #b91c1c;
}
.client-order-items-count {
    font-size: 0.85rem;
}
.client-order-items-btn {
    margin-left: 6px;
    padding: 0;
    font-size: 0.8rem;
}
</style>
<script>
function openOrderItemsModal(id) {
    var el = document.getElementById('order-items-modal-' + id);
    if (el) el.style.display = 'block';
}
function closeOrderItemsModal(id) {
    var el = document.getElementById('order-items-modal-' + id);
    if (el) el.style.display = 'none';
}
function filterClientCampaigns() {
    var input = document.getElementById('clientCampaignSearch');
    var filterText = input ? input.value.toLowerCase() : '';
    var table = document.getElementById('clientsTable');
    if (!table) return;

    var rows = table.getElementsByTagName('tr');

    for (var i = 1; i < rows.length; i++) {
        var row = rows[i];
        var cells = row.getElementsByTagName('td');
        if (!cells.length) continue;

        var clientCell = cells[0];
        var campaignsCell = cells[2];

        var clientText = clientCell ? (clientCell.textContent || clientCell.innerText) : '';
        var campaignsText = campaignsCell ? (campaignsCell.textContent || campaignsCell.innerText) : '';

        var combined = (clientText + ' ' + campaignsText).toLowerCase();

        if (combined.indexOf(filterText) > -1) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    }
}
</script>

<div class="admin-layout">
    {{> admin-sidebar}}

    <main class="admin-main-content">
        <div class="dashboard-header">
            <h2>Meu Perfil</h2>
            <p>Gerencie suas informações de acesso</p>
        </div>

        <div class="profile-container">
            {{#if success}}
            <div class="alert alert-success">
                {{success}}
            </div>
            {{/if}}

            {{#if error}}
            <div class="alert alert-danger">
                {{error}}
            </div>
            {{/if}}

            <form action="/admin/perfil" method="POST" class="admin-form">
                <div class="form-group">
                    <label>Nome de Usuário</label>
                    <input type="text" name="username" class="form-control" value="{{admin.username}}" readonly style="background-color: #f8f9fa;">
                    <small class="text-muted">O nome de usuário não pode ser alterado.</small>
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email" class="form-control" value="{{admin.email}}" required>
                </div>

                <div class="form-group">
                    <label>Nova Senha</label>
                    <input type="password" name="password" class="form-control" placeholder="Deixe em branco para manter a atual">
                </div>

                <div class="form-group">
                    <label>Confirmar Nova Senha</label>
                    <input type="password" name="confirmPassword" class="form-control" placeholder="Confirme a nova senha">
                </div>

                <button type="submit" class="btn btn-primary">Salvar Alterações</button>
            </form>
        </div>
    </main>
</div>

<style>
    .profile-container {
        max-width: 600px;
    }
    
    .admin-form .form-group {
        margin-bottom: 20px;
    }
    
    .admin-form label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #333;
    }
    
    .admin-form .form-control {
        width: 100%;
        padding: 10px 15px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 1rem;
    }
    
    .admin-form .form-control:focus {
        border-color: #0047AB;
        outline: none;
        box-shadow: 0 0 0 3px rgba(0, 71, 171, 0.1);
    }
    
    .alert {
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }
    
    .alert-success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }
    
    .alert-danger {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }
</style>
<div class="admin-layout">
    <!-- Bootstrap JS (Required for Tooltips/Popovers) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    {{> admin-sidebar}}

    <main class="admin-main-content">
        <div class="form-container">
            <div class="dashboard-header" style="flex-direction: row; justify-content: space-between; align-items: center;">
                <div class="header-content">
                    <h2>{{#if campaign.id}}Editar Campanha{{else}}Nova Campanha{{/if}}</h2>
                    <p>{{#if campaign.id}}Atualizar informações da campanha{{else}}Criar uma nova campanha de marketing{{/if}}</p>
                </div>
                <a href="/admin/campanhas" class="btn btn-outline" style="padding: 0.6rem 1.2rem;">
                    <i class="fas fa-arrow-left"></i> Voltar
                </a>
            </div>

            <form action="/admin/campanhas/{{#if campaign.id}}editar/{{campaign.id}}{{else}}nova{{/if}}" method="POST" class="admin-form" enctype="application/x-www-form-urlencoded">
                
                <!-- Section 1: Campaign Info -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="icon-wrapper"><i class="fas fa-bullhorn"></i></div>
                        <h3>Dados da Campanha</h3>
                    </div>
                    <div class="form-grid">
                        <div class="form-group full-width">
                            <label>Nome da Campanha <i class="fas fa-info-circle info-icon" title="Nome visível para identificação da campanha"></i></label>
                            <input type="text" name="title" class="form-control" value="{{campaign.title}}" required placeholder="Ex: Camisa Formandos ADS 2026">
                        </div>
                        
                        <div class="form-group full-width">
                            <label>Descrição (Opcional)</label>
                            <textarea name="description" class="form-control" rows="2" placeholder="Breve descrição da campanha...">{{campaign.description}}</textarea>
                        </div>

                        <div class="form-group">
                            <label>Data de término</label>
                            <input
                                type="date"
                                name="endDate"
                                class="form-control"
                                value="{{campaign.endDate}}"
                            >
                            <small class="form-hint">A campanha começa na data de criação. Informe apenas a data de término.</small>
                        </div>

                        {{#if campaign.accessCode}}
                        <div class="form-group full-width highlight-box">
                            <label>Código de Acesso (Único) <i class="fas fa-info-circle info-icon" title="Link/Senha para o líder da campanha acessar a loja"></i></label>
                            <div class="code-display">
                                <span>{{campaign.accessCode}}</span>
                                <small>Compartilhe este código com o líder da campanha.</small>
                            </div>
                        </div>
                        {{/if}}
                    </div>
                </div>

                <!-- Section 2: Campaign Leader Info -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="icon-wrapper"><i class="fas fa-user-tie"></i></div>
                        <h3>Dados do Líder da Campanha</h3>
                    </div>
                    <div class="form-grid three-columns">
                        <div class="form-group">
                            <label>Nome do Líder</label>
                            <input type="text" name="clientName" class="form-control" value="{{campaign.clientName}}" required placeholder="Nome completo">
                        </div>
                        <div class="form-group">
                            <label>WhatsApp/Celular</label>
                            <input type="text" name="clientPhone" class="form-control" value="{{campaign.clientPhone}}" placeholder="(XX) XXXXX-XXXX">
                        </div>
                        <div class="form-group">
                            <label>Instagram</label>
                            <div class="input-prefix">
                                <span>@</span>
                                <input type="text" name="clientInstagram" class="form-control" value="{{campaign.clientInstagram}}" placeholder="usuario">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 3: Shirts -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="icon-wrapper"><i class="fas fa-tshirt"></i></div>
                        <h3>Configuração das Camisas</h3>
                    </div>
                    
                    <div id="shirts-container">
                        {{#if campaign.shirts}}
                            {{#each campaign.shirts}}
                            <div class="shirt-card">
                                <div class="shirt-card-header">
                                    <h4><i class="fas fa-tag"></i> Camisa #{{@index}}</h4>
                                    <button type="button" class="btn-remove-shirt" onclick="this.closest('.shirt-card').remove()">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                                <div class="shirt-card-body">
                                    <div class="form-group full-width">
                                        <label>Nome do Modelo</label>
                                        <input type="text" name="shirtNames" class="form-control" value="{{this.name}}" required>
                                    </div>
                                    <div class="form-grid three-columns">
                                        <div class="form-group">
                                            <label>Cor</label>
                                            <input type="text" name="shirtColors" class="form-control" value="{{this.color}}">
                                        </div>
                                        <div class="form-group">
                                            <label>Corte <i class="fas fa-info-circle info-icon" title="O tipo de corte do molde da camisa. Inicialmente: tradicional, oversized, cropped, infant."></i></label>
                                            <select name="shirtTypes" class="form-control">
                                                <option value="Tradicional" {{#if (eq this.type 'Tradicional')}}selected{{/if}}>Tradicional</option>
                                                <option value="Oversized" {{#if (eq this.type 'Oversized')}}selected{{/if}}>Oversized</option>
                                                <option value="Cropped" {{#if (eq this.type 'Cropped')}}selected{{/if}}>Cropped</option>
                                                <option value="Infant" {{#if (eq this.type 'Infant')}}selected{{/if}}>Infant</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Preço (R$) <i class="fas fa-info-circle info-icon" title="Valor unitário por camisa"></i></label>
                                            <input type="number" step="0.01" name="shirtPrices" class="form-control" value="{{this.price}}" required>
                                        </div>
                                    </div>
                                    <div class="form-group full-width">
                                        <label>Tamanhos Disponíveis <i class="fas fa-info-circle info-icon" title="Selecione os tamanhos para este modelo"></i></label>
                                        <div class="sizes-wrapper">
                                            <input type="hidden" name="shirtSizes" class="shirt-sizes-input" value="{{this.sizes}}">
                                            <div class="size-options">
                                                <button type="button" class="size-chip" data-value="P">P</button>
                                                <button type="button" class="size-chip" data-value="M">M</button>
                                                <button type="button" class="size-chip" data-value="G">G</button>
                                                <button type="button" class="size-chip" data-value="GG">GG</button>
                                                <button type="button" class="size-chip" data-value="XG">XG</button>
                                                <button type="button" class="size-chip" data-value="XXG">XXG</button>
                                            </div>
                                            <small class="text-muted"><i class="fas fa-mouse-pointer"></i> Selecione os tamanhos disponíveis</small>
                                        </div>
                                    </div>
                                    <div class="form-group full-width">
                                        <label>Imagens do Modelo <i class="fas fa-info-circle info-icon" title="Formatos: JPG, PNG. Máx: 5MB"></i></label>
                                        <div class="image-upload-wrapper">
                                            <input type="hidden" name="shirtImagesJSON" class="shirt-images-json" value='{{#if this.images}}{{json this.images}}{{else}}[]{{/if}}'>
                                            
                                            <!-- Hidden file input -->
                                            <input type="file" accept="image/*" class="form-control shirt-image-file" style="display: none;" onchange="handleImageSelected(this)">
                                            
                                            <!-- Custom Button -->
                                            <div class="upload-trigger" onclick="triggerImageUpload(this)">
                                                <div class="upload-icon">
                                                    <i class="fas fa-cloud-upload-alt"></i>
                                                </div>
                                                <p class="upload-text">Clique para adicionar imagens</p>
                                                <p class="upload-hint">JPG ou PNG (Máx 5MB)</p>
                                            </div>

                                            <div class="image-preview-grid">
                                                {{#if this.images}}
                                                    {{#each this.images}}
                                                    <div class="preview-item">
                                                        <img src="{{this}}" class="preview-img">
                                                        <button type="button" class="btn-remove-image" onclick="removeImage(this)">×</button>
                                                    </div>
                                                    {{/each}}
                                                {{/if}}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            {{/each}}
                        {{else}}
                            <!-- Initial Shirt Card -->
                            <div class="shirt-card">
                                <div class="shirt-card-header">
                                    <h4><i class="fas fa-tag"></i> Camisa Principal</h4>
                                </div>
                                <div class="shirt-card-body">
                                    <div class="form-group full-width">
                                        <label>Nome do Modelo</label>
                                        <input type="text" name="shirtNames" class="form-control" required placeholder="Ex: Camisa Branca Tradicional">
                                    </div>
                                    <div class="form-grid three-columns">
                                        <div class="form-group">
                                            <label>Cor</label>
                                            <input type="text" name="shirtColors" class="form-control" placeholder="Ex: Branca">
                                        </div>
                                        <div class="form-group">
                                            <label>Corte <i class="fas fa-info-circle info-icon" title="O tipo de corte do molde da camisa. Inicialmente: tradicional, oversized, cropped, infant."></i></label>
                                            <select name="shirtTypes" class="form-control">
                                                <option value="Tradicional">Tradicional</option>
                                                <option value="Oversized">Oversized</option>
                                                <option value="Cropped">Cropped</option>
                                                <option value="Infant">Infant</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Preço (R$) <i class="fas fa-info-circle info-icon" title="Valor unitário por camisa"></i></label>
                                            <input type="number" step="0.01" name="shirtPrices" class="form-control" required placeholder="0.00">
                                        </div>
                                    </div>
                                    <div class="form-group full-width">
                                        <label>Tamanhos Disponíveis <i class="fas fa-info-circle info-icon" title="Selecione os tamanhos para este modelo"></i></label>
                                        <div class="sizes-wrapper">
                                            <input type="hidden" name="shirtSizes" class="shirt-sizes-input" value="P, M, G, GG, XG">
                                            <div class="size-options">
                                                <button type="button" class="size-chip" data-value="P">P</button>
                                                <button type="button" class="size-chip" data-value="M">M</button>
                                                <button type="button" class="size-chip" data-value="G">G</button>
                                                <button type="button" class="size-chip" data-value="GG">GG</button>
                                                <button type="button" class="size-chip" data-value="XG">XG</button>
                                                <button type="button" class="size-chip" data-value="XXG">XXG</button>
                                            </div>
                                            <small class="text-muted"><i class="fas fa-mouse-pointer"></i> Selecione os tamanhos disponíveis</small>
                                        </div>
                                    </div>
                                    <div class="form-group full-width">
                                        <label>Imagens do Modelo <i class="fas fa-info-circle info-icon" title="Formatos: JPG, PNG. Máx: 5MB"></i></label>
                                        <div class="image-upload-wrapper">
                                            <input type="hidden" name="shirtImagesJSON" class="shirt-images-json" value="[]">
                                            
                                            <!-- Hidden file input -->
                                            <input type="file" accept="image/*" class="form-control shirt-image-file" style="display: none;" onchange="handleImageSelected(this)">
                                            
                                            <!-- Custom Button -->
                                            <div class="upload-trigger" onclick="triggerImageUpload(this)">
                                                <div class="upload-icon">
                                                    <i class="fas fa-cloud-upload-alt"></i>
                                                </div>
                                                <p class="upload-text">Clique para adicionar imagens</p>
                                                <p class="upload-hint">JPG ou PNG (Máx 5MB)</p>
                                            </div>

                                            <div class="image-preview-grid">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {{/if}}
                    </div>

                    <button type="button" class="btn-add-shirt" onclick="addShirt()">
                        <i class="fas fa-plus-circle"></i> Adicionar Outro Modelo
                    </button>
                </div>

                <div class="form-actions-sticky">
                    <a href="/admin/campanhas" class="btn btn-outline">Cancelar</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Salvar Campanha
                    </button>
                </div>
            </form>
        </div>
    </main>
</div>

<script>
    let currentUploadWrapper = null;

    const SIZE_PRESETS = {
        Tradicional: ['P', 'M', 'G', 'GG', 'XG', 'ExGG', 'P baby look', 'M baby look', 'G baby look'],
        Infant: ['2', '4', '6', '8', '10', '12', '14'],
        Default: ['P', 'M', 'G', 'GG', 'XG']
    };

    document.addEventListener('DOMContentLoaded', function() {
        initChips();
        initShirtTypeListeners();

        const form = document.querySelector('.admin-form');
        if (form) {
            form.addEventListener('submit', function() {
                const btn = form.querySelector('button[type="submit"]');
                if (btn) {
                    const originalText = btn.innerHTML;
                    btn.disabled = true;
                    btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Salvando...`;
                    
                    // Optional: Restore button if page doesn't unload quickly (e.g. client-side validation fails)
                    // But usually for POST redirect it's fine.
                }
            });
        }

        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('size-chip')) {
                e.target.classList.toggle('active');
                updateSizesInput(e.target.parentElement);
            }
        });
    });

    function triggerImageUpload(btn) {
        const wrapper = btn.closest('.image-upload-wrapper');
        const input = wrapper.querySelector('.shirt-image-file');
        input.click();
    }

    function handleImageSelected(input) {
        if (input.files && input.files.length > 0) {
            currentUploadWrapper = input.closest('.image-upload-wrapper');
            const file = input.files[0];

            if (file.size > 5 * 1024 * 1024) { // 5MB
                alert('A imagem deve ter no máximo 5MB.');
                input.value = ''; // Reset input
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                const base64 = e.target.result;
                
                addPreviewImage(base64);
                updateImagesJson(currentUploadWrapper, base64, 'add');
                
                // Reset input to allow adding same file again if deleted
                input.value = ''; 
            };
            reader.readAsDataURL(file);
        }
    }

    function addPreviewImage(base64) {
        const previewGrid = currentUploadWrapper.querySelector('.image-preview-grid');
        
        const placeholder = previewGrid.querySelector('.placeholder-text');
        if (placeholder) placeholder.remove();

        const item = document.createElement('div');
        item.className = 'preview-item';
        item.innerHTML = `
            <img src="${base64}" class="preview-img">
            <button type="button" class="btn-remove-image" onclick="removeImage(this)">×</button>
        `;
        previewGrid.appendChild(item);
    }

    function removeImage(btn) {
        const item = btn.closest('.preview-item');
        const wrapper = btn.closest('.image-upload-wrapper');
        const grid = wrapper.querySelector('.image-preview-grid');
        
        const allItems = Array.from(grid.querySelectorAll('.preview-item'));
        const index = allItems.indexOf(item);

        if (index > -1) {
            updateImagesJson(wrapper, null, 'remove', index);
            item.remove();
        }
    }

    function updateImagesJson(wrapper, data, action, index = -1) {
        const jsonInput = wrapper.querySelector('.shirt-images-json');
        let images = [];
        try {
            images = JSON.parse(jsonInput.value || '[]');
        } catch (e) {
            images = [];
        }

        if (action === 'add') {
            images.push(data);
        } else if (action === 'remove' && index > -1) {
            images.splice(index, 1);
        }

        jsonInput.value = JSON.stringify(images);
    }

    function addShirt() {
        const container = document.getElementById('shirts-container');
        const count = container.querySelectorAll('.shirt-card').length + 1;
        
        const template = `
        <div class="shirt-card">
            <div class="shirt-card-header">
                <h4><i class="fas fa-tag"></i> Camisa #${count}</h4>
                <button type="button" class="btn-remove-shirt" onclick="this.closest('.shirt-card').remove()">
                    <i class="fas fa-trash"></i>
                </button>
            </div>
            <div class="shirt-card-body">
                <div class="form-group full-width">
                    <label>Nome do Modelo</label>
                    <input type="text" name="shirtNames" class="form-control" required placeholder="Ex: Camisa Nova">
                </div>
                <div class="form-grid three-columns">
                    <div class="form-group">
                        <label>Cor</label>
                        <input type="text" name="shirtColors" class="form-control">
                    </div>
                    <div class="form-group">
                        <label>Corte <i class="fas fa-info-circle info-icon" title="O tipo de corte do molde da camisa. Inicialmente: tradicional, oversized, cropped, infant."></i></label>
                        <select name="shirtTypes" class="form-control">
                            <option value="Tradicional">Tradicional</option>
                            <option value="Oversized">Oversized</option>
                            <option value="Cropped">Cropped</option>
                            <option value="Infant">Infant</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Preço (R$) <i class="fas fa-info-circle info-icon" title="Valor unitário por camisa"></i></label>
                        <input type="number" step="0.01" name="shirtPrices" class="form-control" required placeholder="0.00">
                    </div>
                </div>
                <div class="form-group full-width">
                    <label>Tamanhos Disponíveis <i class="fas fa-info-circle info-icon" title="Selecione os tamanhos para este modelo"></i></label>
                    <div class="sizes-wrapper">
                        <input type="hidden" name="shirtSizes" class="shirt-sizes-input" value="">
                        <div class="size-options"></div>
                        <small class="text-muted"><i class="fas fa-mouse-pointer"></i> Selecione os tamanhos disponíveis</small>
                    </div>
                </div>
                <div class="form-group full-width">
                    <label>Imagens do Modelo <i class="fas fa-info-circle info-icon" title="Formatos: JPG, PNG. Máx: 5MB"></i></label>
                    <div class="image-upload-wrapper">
                        <input type="hidden" name="shirtImagesJSON" class="shirt-images-json" value="[]">
                        <input type="file" accept="image/*" class="form-control shirt-image-file" style="display: none;" onchange="handleImageSelected(this)">
                        <div class="upload-trigger" onclick="triggerImageUpload(this)">
                            <div class="upload-icon">
                                <i class="fas fa-cloud-upload-alt"></i>
                            </div>
                            <p class="upload-text">Clique para adicionar imagens</p>
                            <p class="upload-hint">JPG ou PNG (Máx 5MB)</p>
                        </div>
                        <div class="image-preview-grid">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        `;
        
        container.insertAdjacentHTML('beforeend', template);
        initChips();
        initShirtTypeListeners();
    }

    function updateSizesInput(container) {
        const chips = container.querySelectorAll('.size-chip.active');
        const values = Array.from(chips).map(c => c.dataset.value);
        const input = container.closest('.sizes-wrapper').querySelector('.shirt-sizes-input');
        input.value = values.join(', ');
    }

    function initChips() {
        document.querySelectorAll('.sizes-wrapper').forEach(wrapper => {
            const input = wrapper.querySelector('.shirt-sizes-input');
            const card = wrapper.closest('.shirt-card');
            applySizePresetForCard(card, input.value);
        });
    }

    function initShirtTypeListeners() {
        document.querySelectorAll('.shirt-card select[name="shirtTypes"]').forEach(select => {
            if (select.dataset.enhanced === 'true') return;
            select.dataset.enhanced = 'true';
            select.addEventListener('change', function() {
                const card = this.closest('.shirt-card');
                applySizePresetForCard(card, '');
            });
            const card = select.closest('.shirt-card');
            const wrapper = card.querySelector('.sizes-wrapper');
            const input = wrapper.querySelector('.shirt-sizes-input');
            applySizePresetForCard(card, input.value);
        });
    }

    function applySizePresetForCard(card, currentValue) {
        if (!card) return;
        const select = card.querySelector('select[name="shirtTypes"]');
        const wrapper = card.querySelector('.sizes-wrapper');
        if (!select || !wrapper) return;
        const type = select.value || '';
        let preset = SIZE_PRESETS.Default;
        if (type === 'Tradicional') {
            preset = SIZE_PRESETS.Tradicional;
        } else if (type === 'Infant') {
            preset = SIZE_PRESETS.Infant;
        }
        const sizeOptions = wrapper.querySelector('.size-options');
        sizeOptions.innerHTML = '';
        const currentSizes = currentValue ? currentValue.split(',').map(s => s.trim()).filter(Boolean) : [];
        preset.forEach(size => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'size-chip';
            btn.dataset.value = size;
            btn.textContent = size;
            if (!currentSizes.length || currentSizes.includes(size)) {
                btn.classList.add('active');
            }
            sizeOptions.appendChild(btn);
        });
        updateSizesInput(sizeOptions);
    }
</script>

<!-- Cropper Modal Removed -->

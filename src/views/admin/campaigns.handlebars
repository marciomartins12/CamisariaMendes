<div class="admin-layout">
    {{> admin-sidebar}}

    <main class="admin-main-content">
        <div class="dashboard-header-compact">
            <div class="header-title">
                <h2>Gerenciar Campanhas</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Campanhas</li>
                    </ol>
                </nav>
            </div>
            <a href="/admin/campanhas/nova" class="btn btn-primary"><i class="fas fa-plus"></i> Nova Campanha</a>
        </div>

        {{#if success}}
        <div class="alert alert-success">{{success}}</div>
        {{/if}}

        <div class="campaigns-container">
            <div class="search-bar-wrapper">
                <div class="search-input-group">
                    <i class="fas fa-search"></i>
                    <input type="text" id="campaignSearch" class="search-input" placeholder="Buscar por título, líder..." onkeyup="filterCampaigns()">
                </div>
                <div class="filter-group">
                    <select id="statusFilter" class="filter-select" onchange="filterCampaigns()">
                        <option value="">Todos os Status</option>
                        <option value="active">Ativas</option>
                        <option value="inactive">Inativas</option>
                    </select>
                </div>
            </div>

            <div class="campaigns-list">
                {{#if campaigns.length}}
                <div class="table-responsive">
                    <table class="admin-table" id="campaignsTable">
                        <thead>
                            <tr>
                                <th>Campanha</th>
                                <th>Líder</th>
                                <th>Produtos</th>
                                <th>Pedidos</th>
                                <th>Arrecadado</th>
                                <th>Status</th>
                                <th>Período</th>
                                <th style="text-align: right;">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each campaigns}}
                            <tr data-status="{{this.status}}">
                                <td>
                                    <div class="campaign-title-cell">
                                        <strong>{{this.title}}</strong>
                                        <small>{{this.description}}</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="client-cell">
                                        <strong>{{this.clientName}}</strong>
                                        {{#if this.clientPhone}}<small><i class="fas fa-phone-alt"></i> {{this.clientPhone}}</small>{{/if}}
                                    </div>
                                </td>
                                <td>
                                    <span class="stat-value">{{this.productCount}}</span>
                                </td>
                                <td>
                                    <span class="stat-value">{{this.totalOrders}}</span>
                                </td>
                                <td>
                                    <span class="stat-value">R$ {{this.totalRevenue}},00</span>
                                </td>
                                <td>
                                    <span class="badge badge-{{this.status}}">
                                        {{#if (eq this.status 'active')}}Ativa{{/if}}
                                        {{#if (eq this.status 'inactive')}}Inativa{{/if}}
                                        {{#if (eq this.status 'draft')}}Rascunho{{/if}}
                                    </span>
                                </td>
                                <td>
                                    <div class="date-cell">
                                        <small>Início: {{formatDate this.startDate}}</small>
                                        <small>Fim: {{formatDate this.endDate}}</small>
                                    </div>
                                </td>
                                <td style="text-align: right;">
                                    <div class="action-buttons">
                                        <a href="/admin/campanhas/detalhes/{{this.id}}" class="btn-icon details" title="Detalhes"><i class="fas fa-eye"></i></a>
                                        <a href="/admin/campanhas/editar/{{this.id}}" class="btn-icon edit" title="Editar"><i class="fas fa-edit"></i></a>
                                        <form action="/admin/campanhas/deletar/{{this.id}}" method="POST" style="display: inline;" onsubmit="return confirm('Tem certeza que deseja excluir esta campanha?');">
                                            <button type="submit" class="btn-icon delete" title="Excluir"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
                {{else}}
                    <div class="empty-state">
                        <div class="empty-icon"><i class="fas fa-bullhorn"></i></div>
                        <h3>Nenhuma campanha encontrada</h3>
                        <p>Comece criando sua primeira campanha de marketing.</p>
                        <a href="/admin/campanhas/nova" class="btn btn-primary">Criar Campanha</a>
                    </div>
                {{/if}}
            </div>
        </div>
    </main>
</div>

<script>
function filterCampaigns() {
    const input = document.getElementById('campaignSearch');
    const filterText = input.value.toLowerCase();
    const statusFilter = document.getElementById('statusFilter').value;
    const table = document.getElementById('campaignsTable');
    
    if (!table) return;
    
    const tr = table.getElementsByTagName('tr');

    for (let i = 1; i < tr.length; i++) {
        const row = tr[i];
        const titleCell = row.getElementsByTagName('td')[0];
        const clientCell = row.getElementsByTagName('td')[1];
        const rowStatus = row.getAttribute('data-status');
        
        if (titleCell || clientCell) {
            const titleText = titleCell.textContent || titleCell.innerText;
            const clientText = clientCell.textContent || clientCell.innerText;
            
            const matchesText = titleText.toLowerCase().indexOf(filterText) > -1 || 
                                clientText.toLowerCase().indexOf(filterText) > -1;
            
            const matchesStatus = statusFilter === '' || rowStatus === statusFilter;

            if (matchesText && matchesStatus) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        }
    }
}
</script>

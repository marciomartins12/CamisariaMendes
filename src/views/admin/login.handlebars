{{!-- Scoped CSS for Admin Login --}}
<style>
    /* Reset specific for this page wrapper to ensure clean slate */
    .admin-split-screen {
        min-height: calc(100vh - var(--header-height, 70px));
        width: 100%;
        display: flex;
        background: #fff;
        overflow: hidden;
    }

    /* Animation Keyframes */
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeInRight {
        from {
            opacity: 0;
            transform: translateX(-20px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @keyframes floatShape {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
    }

    /* Left Side: Brand & Visuals */
    .admin-brand-side {
        flex: 5; /* 50% width */
        background: linear-gradient(135deg, #001f4d 0%, #0047AB 100%);
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 4rem 6rem;
        color: white;
        overflow: hidden;
    }

    .curve-divider {
        position: absolute;
        top: 0;
        right: -1px;
        bottom: 0;
        width: 100px;
        z-index: 10;
        pointer-events: none;
    }

    .curve-divider svg {
        width: 100%;
        height: 100%;
        fill: #ffffff;
        transform: scaleX(-1);
    }

    @media (max-width: 900px) {
        .admin-split-screen {
            flex-direction: column;
            min-height: auto;
        }
        .admin-brand-side {
            padding: 3rem 2rem;
            flex: none;
            width: 100%;
        }
        .curve-divider {
            width: 100%;
            height: 50px;
            top: auto;
            bottom: -1px;
            right: 0;
            left: 0;
        }
        .curve-divider svg {
            transform: rotate(90deg) scaleX(1); /* Adjust for horizontal */
            display: none; /* Hide for now on mobile to be safe, or use a different SVG */
        }
        .admin-brand-side::after {
             content: '';
             position: absolute;
             bottom: -1px;
             left: 0;
             width: 100%;
             height: 40px;
             background: #ffffff;
             clip-path: ellipse(60% 100% at 50% 100%);
        }
        .admin-form-side {
            padding: 3rem 2rem;
        }
    }

    /* Geometric Decoration */
    .brand-decoration {
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        overflow: hidden;
        z-index: 1;
    }

    .circle-shape {
        position: absolute;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02));
        border: 1px solid rgba(255,255,255,0.05);
        animation: floatShape 8s ease-in-out infinite;
    }

    .shape-1 { width: 500px; height: 500px; top: -100px; right: -100px; animation-delay: 0s; }
    .shape-2 { width: 300px; height: 300px; bottom: -50px; left: -50px; animation-delay: 2s; }
    .shape-3 { width: 100px; height: 100px; top: 20%; left: 20%; opacity: 0.5; animation-delay: 4s; }

    .brand-content {
        position: relative;
        z-index: 2;
        animation: fadeInRight 1s ease-out;
    }

    .brand-logo-large {
        font-family: 'Montserrat', sans-serif;
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        line-height: 1.1;
        letter-spacing: -1px;
    }

    .brand-logo-large span {
        color: #00d4ff;
        text-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
    }

    .brand-description {
        font-size: 1.2rem;
        opacity: 0.9;
        line-height: 1.6;
        max-width: 450px;
        margin-bottom: 3rem;
        color: #e0e6ed;
    }

    .brand-features {
        display: flex;
        gap: 1.5rem;
    }

    .brand-feature-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
        font-size: 0.95rem;
        background: rgba(255,255,255,0.1);
        padding: 0.8rem 1.5rem;
        border-radius: 50px;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: transform 0.3s ease, background 0.3s ease;
    }

    .brand-feature-item:hover {
        transform: translateY(-3px);
        background: rgba(255,255,255,0.15);
    }

    /* Right Side: Login Form */
    .admin-form-side {
        flex: 4; /* 40% width */
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background: #ffffff;
        position: relative;
    }

    .login-container {
        width: 100%;
        max-width: 420px;
        padding: 2rem;
        animation: fadeInUp 0.8s ease-out;
    }

    .form-header {
        margin-bottom: 2.5rem;
    }

    .form-header h2 {
        font-size: 2.2rem;
        color: #1a1a1a;
        font-weight: 800;
        margin-bottom: 0.5rem;
        letter-spacing: -0.5px;
    }

    .form-header p {
        color: #666;
        font-size: 1.05rem;
    }

    /* Modern Inputs */
    .form-group {
        margin-bottom: 1.8rem;
    }

    .form-label {
        display: block;
        font-weight: 700;
        font-size: 0.85rem;
        color: #4a5568;
        margin-bottom: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    .input-wrapper {
        position: relative;
    }

    .form-input {
        width: 100%;
        padding: 1.1rem 1.1rem 1.1rem 3.2rem;
        background: #f8f9fa;
        border: 2px solid #edf2f7;
        border-radius: 12px;
        font-size: 1rem;
        color: #2d3748;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        outline: none;
    }

    .form-input:focus {
        background: #fff;
        border-color: #0047AB;
        box-shadow: 0 0 0 4px rgba(0, 71, 171, 0.15);
        transform: translateY(-2px);
    }

    .input-icon {
        position: absolute;
        left: 1.2rem;
        top: 50%;
        transform: translateY(-50%);
        color: #a0aec0;
        font-size: 1.2rem;
        transition: color 0.3s ease;
    }

    .form-input:focus + .input-icon {
        color: #0047AB;
    }

    /* Action Button */
    .btn-submit {
        width: 100%;
        padding: 1.2rem;
        background: linear-gradient(135deg, #0047AB 0%, #002e70 100%);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 1.5rem;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        position: relative;
        overflow: hidden;
    }

    .btn-submit::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transform: translateX(-100%);
        transition: 0.5s;
    }

    .btn-submit:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px rgba(0, 71, 171, 0.25);
    }

    .btn-submit:hover::after {
        transform: translateX(100%);
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 2rem;
        color: #718096;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.2s;
        padding: 0.5rem 1rem;
        border-radius: 8px;
    }

    .back-link:hover {
        color: #0047AB;
        background: #f7fafc;
    }

    /* Error Message */
    .alert-box {
        background: #fff5f5;
        border-left: 4px solid #ff4d4d;
        padding: 1rem;
        margin-bottom: 1.5rem;
        border-radius: 4px;
        color: #c0392b;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* Responsive */
    @media (max-width: 900px) {
        .admin-brand-side {
            display: none; /* Hide visual side on tablet/mobile for cleaner focus */
        }
        .admin-form-side {
            flex: 1;
            background: #f8f9fa;
        }
        .login-container {
            background: white;
            padding: 3rem 2rem;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
    }
</style>

<div class="admin-split-screen">
    <!-- Left Side: Visual Brand -->
    <div class="admin-brand-side">
        <div class="brand-decoration">
            <div class="circle-shape shape-1"></div>
            <div class="circle-shape shape-2"></div>
            <div class="circle-shape shape-3"></div>
        </div>
        
        <div class="brand-content">
            <h1 class="brand-logo-large">
                Camisaria<br>
                <span>Mendes</span>
            </h1>
            <p class="brand-description">
                Gerencie sua loja com eficiência e estilo. Acesso exclusivo para administradores da Camisaria Mendes.
            </p>
            
            <div class="brand-features">
                <div class="brand-feature-item">
                    <i class="fas fa-shield-alt"></i> Seguro
                </div>
                <div class="brand-feature-item">
                    <i class="fas fa-bolt"></i> Rápido
                </div>
                <div class="brand-feature-item">
                    <i class="fas fa-chart-line"></i> Intuitivo
                </div>
            </div>
        </div>
        
        <!-- Curve Divider -->
        <div class="curve-divider">
            <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                 <path d="M0 0 C 50 0 80 100 0 100 Z"></path>
            </svg>
        </div>
    </div>

    <!-- Right Side: Login Form -->
    <div class="admin-form-side">
        <div class="login-container">
            <div class="form-header">
                <h2>Acesse sua conta</h2>
                <p>Entre com suas credenciais de administrador</p>
            </div>

            {{#if error}}
            <div class="alert-box">
                <i class="fas fa-exclamation-circle"></i>
                <span>{{error}}</span>
            </div>
            {{/if}}

            <form action="/admin/login" method="POST">
                <div class="form-group">
                    <label class="form-label" for="username">Usuário</label>
                    <div class="input-wrapper">
                        <input type="text" id="username" name="username" class="form-input" placeholder="Seu usuário admin" required autofocus>
                        <i class="fas fa-user input-icon"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">Senha</label>
                    <div class="input-wrapper">
                        <input type="password" id="password" name="password" class="form-input" placeholder="Sua senha secreta" required>
                        <i class="fas fa-lock input-icon"></i>
                    </div>
                </div>

                <button type="submit" class="btn-submit">
                    Entrar no Painel <i class="fas fa-arrow-right"></i>
                </button>
            </form>

            <a href="/" class="back-link">
                <i class="fas fa-arrow-left"></i> Voltar para o site
            </a>
            
            <!-- Contact Support Section (Smaller) -->
            <div style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #eee; text-align: center; font-size: 0.8rem; color: #999;">
                <p>Problemas com acesso? <a href="{{whatsappLink}}" style="color: #0047AB; text-decoration: none; font-weight: 600;">Contate o suporte</a></p>
            </div>
        </div>
    </div>
</div>
